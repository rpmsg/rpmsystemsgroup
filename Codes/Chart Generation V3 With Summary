# ---- Iterative repulsion label placement ----
# Start labels offset from their dot, then push apart until no overlaps
label_x = dot_x + 0.4
label_y = dot_y.copy().astype(float)

fig.canvas.draw()   # needed to get renderer for bbox estimates
