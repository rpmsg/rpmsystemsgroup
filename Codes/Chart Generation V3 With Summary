# Estimate label pixel widths using a fixed char-width approximation in data units
x_range = xlims[1] - xlims[0]
y_range = ylims[1] - ylims[0]
fig_w, fig_h = fig.get_size_inches()
char_w_data = x_range / (fig_w * 10)   # ~10 chars per inch
char_h_data = y_range / (fig_h * 14)   # ~14 lines per inch

def label_bbox(lx, ly, name):
    """Approximate data-space bounding box of a label."""
    w = len(name) * char_w_data
    h = char_h_data
    return (lx, ly - h/2, lx + w, ly + h/2)

def boxes_overlap(b1, b2, pad=0.05):
    return not (b1[2]+pad < b2[0] or b2[2]+pad < b1[0] or
                b1[3]+pad < b2[1] or b2[3]+pad < b1[1])

names = df_risk['Player'].tolist()
n = len(names)

# 200 repulsion iterations
for _ in range(200):
    for i in range(n):
        bi = label_bbox(label_x[i], label_y[i], names[i])
        for j in range(n):
            if i == j:
                continue
            bj = label_bbox(label_x[j], label_y[j], names[j])
            if boxes_overlap(bi, bj):
                # Push i away from j vertically (primary) and horizontally (secondary)
                dy = (label_y[i] - label_y[j])
                dx = (label_x[i] - label_x[j])
                if dy == 0: dy = 0.01
                label_y[i] += np.sign(dy) * 0.12
                label_x[i] += np.sign(dx) * 0.04

