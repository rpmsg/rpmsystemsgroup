# ── Helpers ────────────────────────────────────────────────────────────────────
def _shd(p, fill):
    pPr = p._p.get_or_add_pPr()
    shd = OxmlElement('w:shd')
    shd.set(qn('w:val'), 'clear'); shd.set(qn('w:color'), 'auto'); shd.set(qn('w:fill'), fill)
    pPr.append(shd)

def _border(p, side, color_hex, sz=4):
    pPr = p._p.get_or_add_pPr()
    pBdr = OxmlElement('w:pBdr')
    el = OxmlElement(f'w:{side}')
    el.set(qn('w:val'), 'single'); el.set(qn('w:sz'), str(sz))
    el.set(qn('w:space'), '1');    el.set(qn('w:color'), color_hex)
    pBdr.append(el); pPr.append(pBdr)

def _run(p, text, size=9.5, bold=False, italic=False, color=None):
    r = p.add_run(text)
    r.font.name = 'Arial'; r.font.size = Pt(size)
    r.font.bold = bold; r.font.italic = italic
    if color: r.font.color.rgb = color
    return r

def shaded_para(doc, text, fill, color, size=11, bold=False,
                align=WD_ALIGN_PARAGRAPH.LEFT, sb=0, sa=0):
    p = doc.add_paragraph()
    p.alignment = align
    p.paragraph_format.space_before = Pt(sb)
    p.paragraph_format.space_after  = Pt(sa)
    _shd(p, fill)
    _run(p, text, size=size, bold=bold, color=color)
    return p

def cell_head(cell, text, color, sb=8, sa=3):
    p = cell.add_paragraph()
    p.paragraph_format.space_before = Pt(sb)
    p.paragraph_format.space_after  = Pt(sa)
    color_hex = '%02X%02X%02X' % (color[0], color[1], color[2])
    _border(p, 'bottom', color_hex, sz=4)
    _run(p, text, size=10, bold=True, color=color)
    return p

def cell_row(cell, label, detail, label_color, size=9.5, sb=1, sa=1):
    p = cell.add_paragraph()
    p.paragraph_format.space_before = Pt(sb)
    p.paragraph_format.space_after  = Pt(sa)
    p.paragraph_format.left_indent  = Inches(0.15)
    p.paragraph_format.first_line_indent = Inches(-0.15)
    _run(p, f"{label}  ", size=size, bold=True, color=label_color)
    _run(p, detail, size=size)
    return p

def cell_note(cell, text, size=8.5, sb=3, sa=0):
    p = cell.add_paragraph()
    p.paragraph_format.space_before = Pt(sb)
    p.paragraph_format.space_after  = Pt(sa)
    _run(p, text, size=size, italic=True, color=GREY)
    return p

def cell_bullet(cell, label, detail, size=9.5, sb=1, sa=1):
    p = cell.add_paragraph()
    p.paragraph_format.space_before = Pt(sb)
    p.paragraph_format.space_after  = Pt(sa)
    p.paragraph_format.left_indent  = Inches(0.15)
    p.paragraph_format.first_line_indent = Inches(-0.15)
    _run(p, f"• {label}", size=size, bold=True, color=NAVY)
    _run(p, detail, size=size)
    return p

