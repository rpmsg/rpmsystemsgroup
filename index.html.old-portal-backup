          <div class="choice" data-action="multi" data-key="pc3" data-max="2"><span class="chk"></span>Anger or frustration</div>
          <div class="choice" data-action="multi" data-key="pc3" data-max="2"><span class="chk"></span>Sadness or defeat</div>
          <div class="choice" data-action="multi" data-key="pc3" data-max="2"><span class="chk"></span>Numbness or disconnection</div>
          <div class="choice" data-action="multi" data-key="pc3" data-max="2"><span class="chk"></span>Desperation to get back on track</div>
          <div class="choice" data-oth data-action="multi" data-key="pc3" data-max="2"><span class="chk"></span>Other</div>
