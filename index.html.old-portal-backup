// ── Export ─────────────────────────────────────────────────
function exportCSV(type) {
  var labels = {social:'Social_Map_Responses',panic:'Panic_Cycle_Responses',scores:'Pulse_Report_Scores',roster:'Roster_Status'};
  var headers = {
    social:  'athlete_name,team,question_number,nominated_player,type\n',
    panic:   'athlete_name,team,trigger,emotion,body_response,reaction,behavior,aftermath\n',
    scores:  'athlete_name,team,positive_mentions,negative_mentions,social_role\n',
    roster:  'athlete_name,team,status,submitted_date\n'
  };
  // Build sample rows from demo data
  var rows = '';
  var PANIC_DATA = [];
  if (type === 'panic') {
    PANIC_DATA.forEach(function(p){
      rows += '"'+p.name+'","Demo Team","'+p.trigger+'","'+p.emotion+'","'+p.body+'","'+p.reaction+'","'+p.behavior+'","'+p.aftermath+'"\n';
    });
  } else if (type === 'roster') {
    ROSTER.forEach(function(r){
      rows += '"'+r.name+'","'+r.teamName+'","'+r.status+'","'+r.date+'"\n';
    });
  }
  var csv = headers[type] + rows;
  var blob = new Blob([csv], {type:'text/csv'});
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = labels[type] + '_' + new Date().toISOString().slice(0,10) + '.csv';
  a.click();
  URL.revokeObjectURL(a.href);
  showToast('Exported ' + labels[type] + '.csv');
}

// ── Panic PDF ──────────────────────────────────────────────
function generatePanicPDF() {
  if (!PANIC.length) { showToast('No panic cycle responses to export yet.'); return; }
  var today = new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
  var cards = '';
  PANIC.forEach(function(p) {
    function row(label, val) {
      if (!val) return '';
      return '<div style="margin-bottom:10px"><div style="font-size:10px;text-transform:uppercase;letter-spacing:1px;color:#888;margin-bottom:3px">'+label+'</div>'
           + '<div style="font-size:12px;color:#222;line-height:1.5;padding:8px 12px;background:#f5f5f5;border-radius:6px">'+val+'</div></div>';
    }
    cards += '<div style="page-break-after:always;padding:40px 48px;font-family:Arial,sans-serif">'
           + '<div style="border-bottom:3px solid #1A7A4A;padding-bottom:16px;margin-bottom:24px">'
           + '<div style="font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#888;margin-bottom:4px">RPM Systems Group — Panic Cycle Profile</div>'
           + '<div style="font-size:26px;font-weight:900;color:#1A7A4A">'+p.athlete+'</div>'
           + '<div style="font-size:12px;color:#888;margin-top:2px">'+p.teamName+' &nbsp;·&nbsp; Generated '+today+' &nbsp;·&nbsp; Confidential — Practitioner Only</div>'
           + '</div>'
           + row('Primary Trigger', p.trigger)
           + row('Emotional Response', p.emotion)
           + row('Body Response', p.body)
           + row('Immediate Reaction', p.reaction)
           + row('Behavioral Pattern', p.behavior)
           + row('Aftermath / Recovery', p.aftermath)
           + (p.pattern ? '<div style="margin-top:20px;padding:14px 16px;border-left:4px solid #1A7A4A;background:#f0f9f4;border-radius:0 8px 8px 0"><div style="font-size:10px;text-transform:uppercase;letter-spacing:1px;color:#1A7A4A;margin-bottom:4px">Athlete\'s Pattern Sentence</div><div style="font-size:13px;font-style:italic;color:#333">"'+p.pattern+'"</div></div>' : '')
           + '</div>';
  });
  var html = '<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Panic Cycle Profiles</title>'
           + '<style>*{box-sizing:border-box;margin:0;padding:0}body{background:#fff;color:#111}@media print{body{-webkit-print-color-adjust:exact;print-color-adjust:exact}}</style>'
           + '</head><body>'+cards+'</body></html>';
  var w = window.open('', '_blank');
  if (!w) { showToast('Please allow pop-ups to generate the PDF.'); return; }
  w.document.write(html);
  w.document.close();
  w.focus();
  setTimeout(function(){ w.print(); }, 400);
}

