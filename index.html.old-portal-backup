// ── Normalise raw Supabase rows ────────────────────────────
function normaliseTeam(t) {
  return {
    id:       t.id,
    name:     t.name      || '',
    sport:    t.sport     || '',
    school:   t.school    || '',
    season:   t.season    || '',
    code:     t.team_code || t.code || '',
    status:   t.status    || 'active',
    athletes: 0,
    complete: 0
  };
}
function normaliseRoster(r) {
  return {
    id:       r.id,
    name:     r.full_name || r.name || '',
    team:     r.team_id   || r.team || '',
    teamName: r.team_name || r.teamName || '',
    status:   r.status    || 'pending',
    date:     r.completed_at ? new Date(r.completed_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '—'
  };
}
function normaliseCoach(c) {
  return {
    id:       c.id,
    name:     c.full_name || c.name  || '',
    email:    c.email     || '',
    team:     c.team_id   || c.team  || '',
    teamName: c.team_name || c.teamName || '',
    status:   c.status    || 'active'
  };
}

// ── Load data ──────────────────────────────────────────────
function loadAllData() {
  var safe = function(p){ return p.catch(function(){ return []; }); };
  Promise.all([
    safe(supa('teams?select=*&order=created_at.desc')),
    safe(supa('roster?select=*&order=full_name')),
    safe(supa('coaches?select=*&order=full_name')),
    safe(supa('panic_cycle_responses?select=*')),
    safe(supa('social_map_responses?select=*&order=question_number'))
  ]).then(function(results) {
    var rawTeams2   = (results[0] && Array.isArray(results[0])) ? results[0] : [];
    var rawRoster2  = (results[1] && Array.isArray(results[1])) ? results[1] : [];
    var rawCoaches2 = (results[2] && Array.isArray(results[2])) ? results[2] : [];
    var rawPanic    = (results[3] && Array.isArray(results[3])) ? results[3] : [];
    var rawSocial   = (results[4] && Array.isArray(results[4])) ? results[4] : [];
    console.log('[RPM] loadAllData — panic rows:', rawPanic.length, '| social rows:', rawSocial.length, '| panic raw:', results[3]);
    TEAMS   = rawTeams2.map(normaliseTeam);
    ROSTER  = rawRoster2.map(function(r) {
      var norm = normaliseRoster(r);
      if (!norm.teamName) {
        var team = TEAMS.find(function(t){ return t.id === norm.team; });
        norm.teamName = team ? team.name : '';
      }
      return norm;
    });
    COACHES = rawCoaches2.map(function(co) {
      var norm = normaliseCoach(co);
      if (!norm.teamName) {
        var team = TEAMS.find(function(t){ return t.id === norm.team; });
        norm.teamName = team ? team.name : '';
      }
      return norm;
    });
    PANIC = rawPanic.map(function(p) {
      var rosterRow = ROSTER.find(function(r){ return r.id === p.athlete_id; });
      var teamRow   = TEAMS.find(function(t){ return t.id === p.team_id; });
      return {
        id:       p.id,
        athlete:  rosterRow ? rosterRow.name : p.athlete_id,
        team:     p.team_id,
        teamName: teamRow ? teamRow.name : '',
        trigger:   p.q1_trigger           || '',
        signal:    p.q2_first_signal      || '',
        emotion:   p.q3_emotions          || '',
        voice:     p.q4_inner_voice       || '',
        identity:  p.q5_identity_phrase   || '',
        body:      p.q6_body_response     || '',
        reaction:  p.q7_reaction          || '',
        behavior:  p.q8_behavior          || '',
        pattern:   p.q9_pattern_sentence  || '',
        outcome:   p.q10_outcome          || '',
        aftermath: p.q11_aftermath        || ''
      };
    });
    // Build SOCIAL_MAP: group rows by athlete_id, resolving name from ROSTER
    var smByAthlete = {};
    rawSocial.forEach(function(row) {
      var key = row.athlete_id;
      if (!smByAthlete[key]) {
        var rosterRow = ROSTER.find(function(r){ return r.id === key; });
        var teamRow   = TEAMS.find(function(t){ return t.id === row.team_id; });
        smByAthlete[key] = {
          athleteId: key,
          athlete:   rosterRow ? rosterRow.name : key,
          team:      row.team_id,
          teamName:  teamRow ? teamRow.name : '',
          questions: {}
        };
      }
      smByAthlete[key].questions[row.question_number] = {
        n1: row.nominee_1 || '',
        n2: row.nominee_2 || ''
      };
    });
    SOCIAL_MAP = Object.values(smByAthlete);
    // Compute athletes/complete counts from ROSTER (not stored on teams table)
    TEAMS.forEach(function(t) {
      var tr = ROSTER.filter(function(r){ return r.team === t.id; });
      t.athletes = tr.length;
      t.complete  = tr.filter(function(r){ return r.status === 'complete'; }).length;
    });
    renderAll();
  }).catch(function(err) {
    console.error('loadAllData error:', err);
    TEAMS      = [];
    ROSTER     = [];
    COACHES    = [];
    PANIC      = [];
    SOCIAL_MAP = [];
    renderAll();
  });
}

