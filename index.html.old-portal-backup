function saveNewPassword() {
  var err     = document.getElementById('chpass-err');
  var suc     = document.getElementById('chpass-suc');
  var current = document.getElementById('chpass-current').value;
  var newPw   = document.getElementById('chpass-new').value;
  var confirm = document.getElementById('chpass-confirm').value;
  err.style.display = 'none';

  if (!changePassForced && !current) {
    err.textContent = 'Please enter your current password.'; err.style.display = 'block'; return;
  }
  if (newPw.length < 8) {
    err.textContent = 'New password must be at least 8 characters.'; err.style.display = 'block'; return;
  }
  if (newPw !== confirm) {
    err.textContent = 'Passwords do not match.'; err.style.display = 'block'; return;
  }

  var coachId = currentCoachId || localStorage.getItem('rpm_coach_id');
  if (!coachId) { err.textContent = 'Session error — please sign out and back in.'; err.style.display = 'block'; return; }

  // If not forced, verify current password first
  var checkPromise = changePassForced
    ? Promise.resolve(true)
    : supa('coaches?id=eq.' + coachId + '&select=password').then(function(d) {
        return d && d.length && d[0].password === current;
      });

