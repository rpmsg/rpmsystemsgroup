<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RPM Systems Group</title>
<style>
:root{--g:#1A7A4A;--gl:#43B878;--r:#C0392B;--rl:#e05a4a;--d:#0f0f0f;--d2:#1a1a1a;--d3:#242424;--d4:#2e2e2e;--mid:#888;--w:#fff;--bdr:rgba(255,255,255,0.08)}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,-apple-system,sans-serif;background:var(--d);color:var(--w);min-height:100vh}
.screen{display:none}.screen.on{display:flex;flex-direction:column;min-height:100vh}
nav{display:flex;align-items:center;justify-content:space-between;padding:16px 28px;border-bottom:1px solid var(--bdr);background:#0a0a0a;position:sticky;top:0;z-index:99}
.logo{font-size:20px;font-weight:800;letter-spacing:2px}.logo span{color:var(--gl)}
.ntag{font-size:10px;color:var(--mid);letter-spacing:2px;text-transform:uppercase}
.btn{display:inline-flex;align-items:center;justify-content:center;padding:10px 20px;border-radius:7px;font-size:13px;font-weight:600;cursor:pointer;border:none;font-family:inherit;transition:all .18s}
.bp{background:var(--g);color:#fff}.bp:hover{background:var(--gl)}
.bo{background:transparent;color:var(--w);border:1px solid var(--bdr)}.bo:hover{border-color:var(--gl);color:var(--gl)}
.bsm{padding:7px 14px;font-size:11px}.bfw{width:100%}
/* LANDING */
.hero{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 24px;text-align:center}
.eye{font-size:11px;letter-spacing:4px;color:var(--gl);text-transform:uppercase;margin-bottom:16px}
.ht{font-size:clamp(44px,9vw,84px);font-weight:900;line-height:.95;margin-bottom:18px}.ht span{color:var(--gl)}
.hs{font-size:14px;color:var(--mid);max-width:440px;line-height:1.6;margin-bottom:44px}
.cards{display:flex;gap:14px;flex-wrap:wrap;justify-content:center}
.card{background:var(--d2);border:1px solid var(--bdr);border-radius:12px;padding:28px 30px;cursor:pointer;transition:all .2s;min-width:200px;text-align:left}
.card:hover{border-color:var(--g);transform:translateY(-3px)}
.cico{font-size:26px;margin-bottom:12px}.ctit{font-size:17px;font-weight:700;margin-bottom:5px}.cdesc{font-size:12px;color:var(--mid);line-height:1.5}
/* CENTER BOX */
.cw{flex:1;display:flex;align-items:center;justify-content:center;padding:60px 24px}
.box{background:var(--d2);border:1px solid var(--bdr);border-radius:14px;padding:40px;max-width:440px;width:100%}
.box h2{font-size:28px;font-weight:800;margin-bottom:6px}
.box p{font-size:13px;color:var(--mid);margin-bottom:24px;line-height:1.5}
.tag{display:inline-block;padding:3px 10px;border-radius:20px;font-size:10px;letter-spacing:1px;background:rgba(26,122,74,.15);color:var(--gl);margin-bottom:10px}
.fld{margin-bottom:16px}.fld label{display:block;font-size:10px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;margin-bottom:6px}
.fld input{width:100%;background:var(--d3);border:1px solid var(--d4);border-radius:7px;padding:12px 14px;color:var(--w);font-family:inherit;font-size:14px;outline:none;transition:border-color .18s}
.fld input:focus{border-color:var(--g)}.fld input::placeholder{color:var(--mid)}
.err{color:var(--rl);font-size:12px;margin-bottom:12px;display:none}
/* INTAKE */
.il{flex:1;display:grid;grid-template-columns:230px 1fr}
.sb{background:var(--d2);border-right:1px solid var(--bdr);padding:24px 18px;display:flex;flex-direction:column;gap:2px;overflow-y:auto}
.sbsec{font-size:9px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;padding:8px 0 4px;margin-top:8px}
.sbsec:first-child{margin-top:0}
.sbi{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:5px;font-size:12px;color:var(--mid);transition:all .15s}
.sbi.done{color:var(--gl)}.sbi.active{background:rgba(26,122,74,.13);color:var(--w);border-left:2px solid var(--gl)}
.sbd{width:5px;height:5px;border-radius:50%;background:var(--d4);flex-shrink:0}
.sbi.done .sbd{background:var(--gl)}.sbi.active .sbd{background:var(--gl)}
.im{padding:40px;overflow-y:auto;max-width:660px}
/* BLOCKS */
.qb{display:none}.qb.on{display:block}
.brk{display:none;flex-direction:column;align-items:center;justify-content:center;min-height:calc(100vh - 56px);text-align:center;padding:60px 24px}
.brk.on{display:flex}
.brk .bico{font-size:50px;margin-bottom:18px}
.brk h2{font-size:38px;font-weight:800;margin-bottom:12px}
.brk p{font-size:14px;color:var(--mid);max-width:400px;line-height:1.6;margin-bottom:26px}
.pm{margin-bottom:32px}.pml{font-size:10px;color:var(--mid);margin-bottom:6px;letter-spacing:.5px}
.pt{height:3px;background:var(--d4);border-radius:2px;overflow:hidden}
.pf{height:100%;background:linear-gradient(90deg,var(--g),var(--gl));border-radius:2px;transition:width .4s}
.qmeta{font-size:10px;letter-spacing:3px;color:var(--gl);text-transform:uppercase;margin-bottom:8px}
.qt{font-size:clamp(16px,2.6vw,21px);font-weight:600;line-height:1.4;margin-bottom:6px}
.qs{font-size:12px;color:var(--mid);margin-bottom:24px;line-height:1.5}
.choices{display:flex;flex-direction:column;gap:8px;margin-bottom:24px}
.choice{display:flex;align-items:center;gap:12px;background:var(--d2);border:1px solid var(--d4);border-radius:8px;padding:12px 15px;cursor:pointer;transition:all .15s;font-size:13px;color:var(--mid)}
.choice:hover{border-color:var(--g);color:var(--w)}
.choice.sel{border-color:var(--gl);color:var(--w);background:rgba(26,122,74,.12)}
.chk{width:16px;height:16px;border-radius:4px;border:2px solid var(--d4);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:9px;transition:all .15s}
.choice.sel .chk{background:var(--gl);border-color:var(--gl)}
.choice.sel .chk::after{content:'✓';color:#fff}
.ta textarea{width:100%;background:var(--d2);border:1px solid var(--d4);border-radius:8px;padding:12px;color:var(--w);font-family:inherit;font-size:13px;line-height:1.6;resize:vertical;min-height:80px;outline:none;transition:border-color .18s;margin-bottom:24px}
.ta textarea:focus{border-color:var(--g)}
.qnav{display:flex;gap:8px}
/* ROSTER GRID */
.rg{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:6px;margin-bottom:24px}
.ri{display:flex;align-items:center;gap:8px;background:var(--d2);border:1px solid var(--d4);border-radius:7px;padding:10px 12px;cursor:pointer;transition:all .15s;font-size:12px;color:var(--mid)}
.ri:hover{border-color:var(--g);color:var(--w)}
.ri.sel{border-color:var(--gl);color:var(--w);background:rgba(26,122,74,.12)}
.ri.neg{border-color:var(--rl);color:var(--w);background:rgba(192,57,43,.1)}
.av{width:24px;height:24px;border-radius:50%;background:var(--d3);display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:var(--mid);flex-shrink:0}
.ri.sel .av{background:rgba(26,122,74,.3);color:var(--gl)}
.ri.neg .av{background:rgba(192,57,43,.3);color:var(--rl)}
/* CONFIRM */
.cfwrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:60px 24px}
.cfwrap .ico{font-size:56px;margin-bottom:18px}
.cfwrap h2{font-size:46px;font-weight:900;margin-bottom:12px}
.cfwrap p{font-size:14px;color:var(--mid);max-width:400px;margin:0 auto 32px;line-height:1.6}
.cfcard{background:var(--d2);border:1px solid var(--bdr);border-radius:12px;padding:22px 28px;max-width:360px;text-align:left}
.cfcard h4{font-size:9px;letter-spacing:2px;color:var(--gl);text-transform:uppercase;margin-bottom:12px}
.cfrow{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--bdr);font-size:12px}
.cfrow:last-child{border-bottom:none}.cfrow span:first-child{color:var(--mid)}.cfrow span:last-child{font-weight:600}
/* DASHBOARD */
.dl{flex:1;display:grid;grid-template-columns:250px 1fr}
.dsb{background:var(--d2);border-right:1px solid var(--bdr);padding:22px 16px;overflow-y:auto}
.dsb h3{font-size:9px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;margin-bottom:10px}
.tc{background:var(--d3);border:1px solid var(--bdr);border-radius:9px;padding:14px;margin-bottom:8px;cursor:pointer;transition:all .18s}
.tc:hover,.tc.active{border-color:var(--g)}
.tcn{font-size:13px;font-weight:600;margin-bottom:3px}.tcm{font-size:10px;color:var(--mid)}
.tcbar{margin-top:8px;height:3px;background:var(--d4);border-radius:2px;overflow:hidden}
.tcfill{height:100%;background:var(--gl);border-radius:2px}
.dm{padding:30px;overflow-y:auto}
.dhd{margin-bottom:26px}.dhd h2{font-size:32px;font-weight:900;letter-spacing:.5px}.dhd p{font-size:12px;color:var(--mid);margin-top:3px}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:26px}
.stat{background:var(--d2);border:1px solid var(--bdr);border-radius:9px;padding:16px}
.sv{font-size:32px;font-weight:900}.sv.g{color:var(--gl)}.sv.r{color:var(--rl)}
.sl{font-size:10px;color:var(--mid);margin-top:3px}
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.stit{font-size:20px;font-weight:800}
.rt{background:var(--d2);border:1px solid var(--bdr);border-radius:10px;overflow:hidden;margin-bottom:26px}
.rth{display:grid;grid-template-columns:1fr 100px 130px 80px;padding:10px 16px;background:var(--d3);font-size:9px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;border-bottom:1px solid var(--bdr)}
.rtr{display:grid;grid-template-columns:1fr 100px 130px 80px;padding:12px 16px;border-bottom:1px solid var(--bdr);font-size:12px;align-items:center}
.rtr:last-child{border-bottom:none}.rtr:hover{background:rgba(255,255,255,.02)}
.pill{display:inline-flex;align-items:center;padding:3px 8px;border-radius:20px;font-size:9px}
.pill.done{background:rgba(26,122,74,.2);color:var(--gl)}.pill.pend{background:rgba(136,136,136,.12);color:var(--mid)}
.rtag{display:inline-flex;padding:2px 7px;border-radius:4px;font-size:9px}
.rtag.inf{background:rgba(26,122,74,.2);color:var(--gl)}.rtag.rej{background:rgba(192,57,43,.2);color:var(--rl)}
.rtag.iso{background:rgba(100,100,200,.2);color:#9090ff}.rtag.non{background:rgba(136,136,136,.1);color:var(--mid)}
.charts{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:26px}
.cc{background:var(--d2);border:1px solid var(--bdr);border-radius:10px;padding:20px}
.cc.full{grid-column:1/-1}.cct{font-size:9px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;margin-bottom:16px}
.bl{display:flex;flex-direction:column;gap:11px}
.br{display:flex;align-items:center;gap:10px}
.bn{font-size:12px;width:110px;flex-shrink:0;color:#e8e8e8;font-weight:500}
.bt{flex:1;height:8px;background:#2a2a2a;border-radius:4px;overflow:hidden}
.bf{height:100%;border-radius:4px}
.bv{font-size:11px;color:#e8e8e8;font-weight:600;width:28px;text-align:right}
.rqg{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.rq{background:var(--d3);border-radius:7px;padding:12px}
.rqt{font-size:9px;letter-spacing:1px;text-transform:uppercase;margin-bottom:6px}
.rqt.g{color:var(--gl)}.rqt.r{color:var(--rl)}.rqt.b{color:#9090ff}.rqt.y{color:#f0b030}
.rqd{font-size:9px;color:var(--mid);margin-bottom:8px}
.rqp{display:flex;flex-wrap:wrap;gap:4px}
.rqpi{font-size:10px;padding:2px 7px;border-radius:3px;background:rgba(255,255,255,.06);color:var(--mid)}
.suggs{display:flex;flex-direction:column;gap:9px}
.si{display:flex;gap:11px;align-items:flex-start;padding:12px;background:var(--d3);border-radius:7px}
.sico{font-size:16px;flex-shrink:0}.stxt{font-size:12px;line-height:1.6;color:var(--mid)}
/* PANIC PROFILE */
.pp{background:var(--d2);border:1px solid var(--bdr);border-radius:10px;overflow:hidden;margin-bottom:26px}
.pp-banner{background:linear-gradient(135deg,rgba(192,57,43,.18) 0%,rgba(26,122,74,.12) 100%);border-bottom:1px solid var(--bdr);padding:18px 22px;display:flex;align-items:center;gap:14px}
.pp-banner-ico{font-size:28px;flex-shrink:0}
.pp-banner-text h3{font-size:15px;font-weight:800;margin-bottom:2px}
.pp-banner-text p{font-size:11px;color:var(--mid);line-height:1.5}
.pp-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:9px;letter-spacing:1px;background:rgba(192,57,43,.15);color:#e05a4a;margin-top:6px}
.pp-grid{display:grid;grid-template-columns:1fr 1fr;gap:0}
.pp-col{padding:20px 22px}
.pp-col+.pp-col{border-left:1px solid var(--bdr)}
.pp-col-title{font-size:9px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;margin-bottom:14px}
.pp-row{margin-bottom:14px}
.pp-row:last-child{margin-bottom:0}
.pp-label{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:5px}
.pp-name{font-size:11px;color:var(--w);line-height:1.4;max-width:75%}
.pp-pct{font-size:10px;color:var(--mid)}
.pp-track{height:5px;background:var(--d3);border-radius:3px;overflow:hidden}
.pp-fill-r{height:100%;border-radius:3px;background:linear-gradient(90deg,#8B1A10,#C0392B)}
.pp-fill-g{height:100%;border-radius:3px;background:linear-gradient(90deg,#1d8f5a,#52d98a)}
.pp-fill-y{height:100%;border-radius:3px;background:linear-gradient(90deg,#7a5a1a,#f0b030)}
.pp-fill-b{height:100%;border-radius:3px;background:linear-gradient(90deg,#1a3a7a,#5080e0)}
.pp-insight{background:var(--d3);border-radius:0 0 10px 10px;border-top:1px solid var(--bdr);padding:14px 22px;display:flex;gap:22px;flex-wrap:wrap}
.pp-ins-item{display:flex;align-items:center;gap:8px}
.pp-ins-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.pp-ins-dot.r{background:var(--rl)}.pp-ins-dot.g{background:var(--gl)}.pp-ins-dot.y{background:#f0b030}.pp-ins-dot.b{background:#5080e0}
.pp-ins-txt{font-size:11px;color:var(--mid)}
.pp-ins-txt strong{color:var(--w)}
/* REPORT MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;display:none;align-items:center;justify-content:center;padding:20px}
.modal-overlay.on{display:flex}
.modal{background:var(--d2);border:1px solid var(--bdr);border-radius:14px;width:100%;max-width:780px;max-height:90vh;display:flex;flex-direction:column;overflow:hidden}
.modal-head{display:flex;align-items:center;justify-content:space-between;padding:18px 24px;border-bottom:1px solid var(--bdr);flex-shrink:0}
.modal-head h3{font-size:17px;font-weight:800}
.modal-head p{font-size:11px;color:var(--mid);margin-top:2px}
.modal-close{width:30px;height:30px;border-radius:50%;background:var(--d3);border:1px solid var(--bdr);color:var(--mid);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;transition:all .15s}
.modal-close:hover{border-color:var(--rl);color:var(--rl)}
.modal-body{overflow-y:auto;padding:22px 24px;flex:1}
.modal-charts{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
.modal-chart-card{background:var(--d3);border:1px solid var(--bdr);border-radius:9px;overflow:hidden}
.modal-chart-card.full{grid-column:1/-1}
.modal-chart-label{padding:8px 12px;font-size:9px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;border-bottom:1px solid var(--bdr)}
.modal-chart-card img{width:100%;display:block;background:#fff}
.modal-doc-row{display:flex;align-items:center;gap:12px;background:var(--d3);border:1px solid var(--bdr);border-radius:9px;padding:14px 16px}
.modal-doc-ico{font-size:24px;flex-shrink:0}
.modal-doc-info{flex:1}
.modal-doc-info strong{font-size:13px;display:block;margin-bottom:2px}
.modal-doc-info span{font-size:11px;color:var(--mid)}
.modal-foot{padding:16px 24px;border-top:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;gap:12px}
.modal-foot p{font-size:11px;color:var(--mid)}
.modal-dl-progress{display:none;align-items:center;gap:10px;font-size:12px;color:var(--gl)}
.modal-dl-progress.on{display:flex}
@keyframes spin{to{transform:rotate(360deg)}}
@media(max-width:600px){.modal-charts{grid-template-columns:1fr}.modal-chart-card.full{grid-column:1}}

@media(max-width:700px){
  .il{grid-template-columns:1fr}
  .sb{display:none}
  .im{padding:20px}
  .rg{grid-template-columns:1fr 1fr}
  .dl{grid-template-columns:1fr}
  .dsb{display:none}
  .stats{grid-template-columns:1fr 1fr}
  .charts{grid-template-columns:1fr}
  .cc.full{grid-column:1}
  .rth{grid-template-columns:1fr 80px}
  .rtr{grid-template-columns:1fr 80px}
  .rth>*:nth-child(n+3),.rtr>*:nth-child(n+3){display:none}
  .rqg{grid-template-columns:1fr}
  .hero{padding:40px 20px}
  .ht{font-size:clamp(36px,10vw,60px)}
  .box{padding:28px 20px}
  nav{padding:14px 18px}
  .ntag{display:none}
  .brk{padding:40px 20px}
  .brk h2{font-size:28px}
}
@media(max-width:400px){
  .rg{grid-template-columns:1fr}
}
@media(max-width:480px){
  /* Landing — cards stack and stretch full width */
  .cards{flex-direction:column;align-items:stretch}
  .card{min-width:unset}
  /* Progress bar — thicker and label readable */
  .pt{height:6px}
  .pml{font-size:12px;letter-spacing:0}
  /* Section + question meta labels */
  .qmeta{font-size:11px;letter-spacing:2px}
  .qs{font-size:13px}
  /* Choice buttons — taller tap targets, bigger text */
  .choice{padding:15px;font-size:14px;gap:14px}
  .chk{width:20px;height:20px;flex-shrink:0}
  /* Roster grid items — taller tap targets */
  .ri{padding:13px 14px;font-size:13px;gap:10px}
  .av{width:28px;height:28px;font-size:9px}
  /* Nav buttons — full width stacked */
  .qnav{flex-direction:column;gap:10px}
  .qnav .btn{width:100%;padding:15px 20px;font-size:14px}
  /* Text area — easier to type on phone */
  .ta textarea{min-height:110px;font-size:14px}
  /* Box forms — tighten padding slightly */
  .box{padding:24px 18px}
  /* Break screens — less top/bottom space, full-width CTA */
  .brk{padding:30px 20px}
  .brk .btn{width:100%;max-width:320px;padding:15px 20px;font-size:15px}
}

/* ADMIN PANEL */
:root{--g:#1A7A4A;--gl:#43B878;--r:#C0392B;--rl:#e05a4a;--d:#0f0f0f;--d2:#1a1a1a;--d3:#242424;--d4:#2e2e2e;--mid:#888;--w:#fff;--bdr:rgba(255,255,255,0.08);--amber:#b07800;--amberl:#f0b030}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,-apple-system,sans-serif;background:var(--d);color:var(--w);min-height:100vh}

/* NAV */
nav{display:flex;align-items:center;justify-content:space-between;padding:14px 28px;border-bottom:1px solid var(--bdr);background:#0a0a0a;position:sticky;top:0;z-index:99}
.logo{font-size:20px;font-weight:800;letter-spacing:2px}.logo span{color:var(--gl)}
.nav-badge{font-size:9px;letter-spacing:2px;color:var(--rl);text-transform:uppercase;background:rgba(192,57,43,.15);border:1px solid rgba(192,57,43,.3);padding:3px 10px;border-radius:20px;margin-left:10px}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:10px 20px;border-radius:7px;font-size:13px;font-weight:600;cursor:pointer;border:none;font-family:inherit;transition:all .18s}
.bp{background:var(--g);color:#fff}.bp:hover{background:var(--gl)}
.br{background:var(--r);color:#fff}.br:hover{background:var(--rl)}
.bo{background:transparent;color:var(--w);border:1px solid var(--bdr)}.bo:hover{border-color:var(--gl);color:var(--gl)}
.ba{background:rgba(176,120,0,.2);color:var(--amberl);border:1px solid rgba(176,120,0,.35)}.ba:hover{background:rgba(176,120,0,.35)}
.bsm{padding:7px 14px;font-size:11px}.bxs{padding:5px 10px;font-size:10px}.bfw{width:100%}

/* LAYOUT */
.admin-layout{display:grid;grid-template-columns:220px 1fr;min-height:calc(100vh - 53px)}
.sidebar{background:var(--d2);border-right:1px solid var(--bdr);padding:20px 14px;position:sticky;top:53px;height:calc(100vh - 53px);overflow-y:auto}
.sidebar-section{font-size:9px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;padding:10px 8px 6px;margin-top:10px}
.sidebar-section:first-child{margin-top:0}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 10px;border-radius:6px;font-size:12px;color:var(--mid);cursor:pointer;transition:all .15s;border-left:2px solid transparent}
.nav-item:hover{color:var(--w);background:rgba(255,255,255,.04)}
.nav-item.active{color:var(--w);background:rgba(26,122,74,.12);border-left-color:var(--gl)}
.nav-item .ni{font-size:14px;flex-shrink:0}
.main{padding:32px;overflow-y:auto}

/* SECTION PAGES */
.section{display:none}.section.on{display:block}

/* PAGE HEADER */
.page-hd{margin-bottom:26px}
.page-hd h1{font-size:28px;font-weight:900}
.page-hd p{font-size:12px;color:var(--mid);margin-top:4px}
.page-hd-row{display:flex;align-items:flex-start;justify-content:space-between;gap:12px}

/* CARDS / STATS */
.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:28px}
.stat-card{background:var(--d2);border:1px solid var(--bdr);border-radius:9px;padding:18px}
.stat-card .sv{font-size:30px;font-weight:900}.sv.g{color:var(--gl)}.sv.r{color:var(--rl)}.sv.a{color:var(--amberl)}
.stat-card .sl{font-size:10px;color:var(--mid);margin-top:3px}

/* TABLE */
.tbl-wrap{background:var(--d2);border:1px solid var(--bdr);border-radius:10px;overflow:hidden;margin-bottom:24px}
.tbl-hd{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--bdr);background:var(--d3)}
.tbl-hd h3{font-size:14px;font-weight:700}
.tbl-cols{display:grid;padding:10px 18px;background:var(--d3);font-size:9px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;border-bottom:1px solid var(--bdr)}
.tbl-row{display:grid;padding:13px 18px;border-bottom:1px solid var(--bdr);font-size:12px;align-items:center;transition:background .12s}
.tbl-row:last-child{border-bottom:none}
.tbl-row:hover{background:rgba(255,255,255,.02)}
.tbl-empty{padding:28px;text-align:center;font-size:12px;color:var(--mid)}

/* PILLS & TAGS */
.pill{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:9px;font-weight:600}
.pill-g{background:rgba(26,122,74,.2);color:var(--gl)}
.pill-r{background:rgba(192,57,43,.2);color:var(--rl)}
.pill-a{background:rgba(176,120,0,.2);color:var(--amberl)}
.pill-mid{background:rgba(136,136,136,.12);color:var(--mid)}

/* FORM PANEL */
.form-panel{background:var(--d2);border:1px solid var(--bdr);border-radius:12px;padding:28px;max-width:520px;margin-bottom:24px}
.form-panel h3{font-size:16px;font-weight:700;margin-bottom:4px}
.form-panel p{font-size:12px;color:var(--mid);margin-bottom:20px}
.fld{margin-bottom:16px}
.fld label{display:block;font-size:10px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;margin-bottom:6px}
.fld input,.fld select,.fld textarea{width:100%;background:var(--d3);border:1px solid var(--d4);border-radius:7px;padding:11px 14px;color:var(--w);font-family:inherit;font-size:13px;outline:none;transition:border-color .18s}
.fld input:focus,.fld select:focus,.fld textarea:focus{border-color:var(--g)}
.fld input::placeholder,.fld textarea::placeholder{color:var(--mid)}
.fld select option{background:var(--d3)}
.fld textarea{resize:vertical;min-height:70px}
.fld-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-actions{display:flex;gap:8px;margin-top:4px}
.err{color:var(--rl);font-size:11px;margin-bottom:10px;display:none}
.suc{color:var(--gl);font-size:11px;margin-bottom:10px;display:none}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.78);z-index:200;display:none;align-items:center;justify-content:center;padding:20px}
.modal-overlay.on{display:flex}
.modal{background:var(--d2);border:1px solid var(--bdr);border-radius:14px;width:100%;max-width:520px;overflow:hidden}
.modal-head{display:flex;align-items:center;justify-content:space-between;padding:18px 22px;border-bottom:1px solid var(--bdr)}
.modal-head h3{font-size:16px;font-weight:700}
.modal-body{padding:22px}
.modal-foot{padding:14px 22px;border-top:1px solid var(--bdr);display:flex;justify-content:flex-end;gap:8px}
.modal-close-btn{width:28px;height:28px;border-radius:50%;background:var(--d3);border:1px solid var(--bdr);color:var(--mid);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;transition:all .15s}
.modal-close-btn:hover{border-color:var(--rl);color:var(--rl)}

/* QR CODE */
.qr-wrap{display:flex;flex-direction:column;align-items:center;gap:12px;padding:20px}
.qr-box{background:#fff;padding:16px;border-radius:10px}
.qr-link{font-size:11px;color:var(--mid);text-align:center;word-break:break-all;max-width:300px}
.qr-actions{display:flex;gap:8px}

/* UPLOAD ZONE */
.upload-zone{border:2px dashed var(--d4);border-radius:9px;padding:28px;text-align:center;cursor:pointer;transition:all .2s;margin-bottom:16px}
.upload-zone:hover,.upload-zone.drag{border-color:var(--gl);background:rgba(26,122,74,.06)}
.upload-zone p{font-size:12px;color:var(--mid);margin-top:6px}
.upload-zone .uz-ico{font-size:28px;margin-bottom:6px}

/* PANIC CYCLE CARD */
.pc-card{background:var(--d3);border:1px solid var(--bdr);border-radius:9px;padding:16px;margin-bottom:10px}
.pc-card-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.pc-card-name{font-size:13px;font-weight:700}
.pc-stages{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.pc-stage{background:var(--d2);border-radius:6px;padding:10px}
.pc-stage-lbl{font-size:9px;letter-spacing:1px;color:var(--gl);text-transform:uppercase;margin-bottom:4px}
.pc-stage-val{font-size:11px;color:var(--mid);line-height:1.4}

/* LOGIN */
.login-wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:60px 24px}
.login-box{background:var(--d2);border:1px solid var(--bdr);border-radius:14px;padding:40px;max-width:400px;width:100%}
.login-box h2{font-size:26px;font-weight:900;margin-bottom:6px}
.login-box p{font-size:13px;color:var(--mid);margin-bottom:24px}

/* NOTICE */
.notice{display:flex;align-items:flex-start;gap:10px;padding:12px 14px;border-radius:8px;font-size:12px;margin-bottom:18px}
.notice.warn{background:rgba(176,120,0,.12);border:1px solid rgba(176,120,0,.3);color:var(--amberl)}
.notice.info{background:rgba(26,122,74,.1);border:1px solid rgba(26,122,74,.3);color:var(--gl)}
.notice.danger{background:rgba(192,57,43,.1);border:1px solid rgba(192,57,43,.3);color:var(--rl)}
.notice-ico{font-size:14px;flex-shrink:0;margin-top:1px}
.notice p{color:inherit;margin-bottom:0;font-size:12px}

/* EXPORT */
.export-card{background:var(--d2);border:1px solid var(--bdr);border-radius:10px;padding:20px 22px;display:flex;align-items:center;gap:16px;margin-bottom:12px}
.export-ico{font-size:28px;flex-shrink:0}
.export-info{flex:1}
.export-info strong{font-size:13px;display:block;margin-bottom:3px}
.export-info span{font-size:11px;color:var(--mid)}

/* PROGRESS */
.prog-bar{height:4px;background:var(--d4);border-radius:2px;overflow:hidden;margin-top:8px}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--g),var(--gl));border-radius:2px;transition:width .4s}

.ham-btn{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;background:none;border:none}
.ham-btn span{display:block;width:22px;height:2px;background:var(--w);border-radius:2px;transition:all .2s}
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:90}
.sidebar-overlay.on{display:block}
.sidebar.open{display:flex!important;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:100;width:240px;padding-top:16px}
@media(max-width:800px){
  .admin-layout{grid-template-columns:1fr}
  .sidebar{display:none}.ham-btn{display:flex}
  .stat-row{grid-template-columns:1fr 1fr}
  .fld-row{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- LANDING -->
<div id="s-land" class="screen on">
  <nav>
    <div class="logo">RPM<span>.</span>SG</div>
    <div class="ntag">Mental Performance Portal</div>
    <div style="display:flex;gap:8px">
      <button class="btn bo bsm" data-action="show" data-target="s-code">Athlete Login</button>
