function handleCSV(input) {
  var file = input.files[0];
  if (!file) return;
  document.getElementById('csv-filename').textContent = file.name;
  var reader = new FileReader();
  reader.onload = function(e) {
    var lines = e.target.result.split('\n').map(function(l){ return l.trim().replace(/^"|"$/g,''); }).filter(Boolean);
    if (!lines.length) {
      document.getElementById('csv-err').textContent = 'File appears to be empty.';
      document.getElementById('csv-err').style.display = 'block';
      return;
    }
    // Detect header row — check first column header only
    var nameHeaders = ['full_name','name','athlete','athlete name','player','player name','fullname','first name','first_name','player first name'];
    var lastNameHeaders = ['last name','last_name','player last name','lastname','surname'];
    var firstColHeader = lines[0].split(',')[0].toLowerCase().replace(/[^a-z_ ]/g,'').trim();
    var secondColHeader = lines[0].split(',')[1] ? lines[0].split(',')[1].toLowerCase().replace(/[^a-z_ ]/g,'').trim() : '';
    var hasHeader = nameHeaders.some(function(h){ return firstColHeader === h; });
    if (!hasHeader && /^[a-z_]+$/.test(firstColHeader)) hasHeader = true;
    var twoColName = hasHeader && lastNameHeaders.some(function(h){ return secondColHeader === h; });
    csvParsedNames = (hasHeader ? lines.slice(1) : lines)
      .map(function(l){
        var cols = l.split(',');
        var first = cols[0] ? cols[0].trim() : '';
        var last = (twoColName && cols[1]) ? cols[1].trim() : '';
        return window.toTitleCase(last ? first + ' ' + last : first);
      })
      .filter(Boolean);
    if (!csvParsedNames.length) {
      document.getElementById('csv-err').textContent = 'No athlete names found in file.';
      document.getElementById('csv-err').style.display = 'block';
      return;
    }
    document.getElementById('csv-count').textContent = csvParsedNames.length + ' athletes found in file:';
    document.getElementById('csv-names').innerHTML = csvParsedNames.map(function(n){ return '<div>' + n + '</div>'; }).join('');
    document.getElementById('csv-preview').style.display = 'block';
    document.getElementById('csv-submit-btn').style.display = '';
    document.getElementById('csv-err').style.display = 'none';
  };
  reader.readAsText(file);
}

function submitCSV() {
  var team = document.getElementById('csv-team').value;
  var err  = document.getElementById('csv-err');
  var suc  = document.getElementById('csv-suc');
  if (!team) { err.textContent='Please select a team.'; err.style.display='block'; return; }
  if (!csvParsedNames.length) { err.textContent='No names found in file.'; err.style.display='block'; return; }
  var btn = document.getElementById('csv-submit-btn');
  btn.textContent = 'Uploading...'; btn.style.opacity='.6'; btn.style.pointerEvents='none';
  var rows = csvParsedNames.map(function(n){ return {team_id:team, full_name:n.trim(), status:'pending'}; });
  // Insert in chunks of 50
  function insertChunk(idx) {
    if (idx >= rows.length) {
      btn.textContent='Upload Roster'; btn.style.opacity=''; btn.style.pointerEvents='';
      suc.textContent = csvParsedNames.length + ' athletes uploaded successfully.';
      suc.style.display = 'block';
      setTimeout(function(){ closeModal('modal-csv'); suc.style.display='none';
        document.getElementById('csv-preview').style.display='none';
        document.getElementById('csv-filename').textContent='';
        csvParsedNames=[];
        window.loadAllData();
      }, 2000);
      return;
    }
    var chunk = rows.slice(idx, idx+50);
    supa('roster', 'POST', chunk)
      .then(function(){ insertChunk(idx+50); })
      .catch(function(){ btn.textContent='Upload Roster'; btn.style.opacity=''; btn.style.pointerEvents='';
        err.textContent='Upload failed at row '+(idx+1)+'. Please try again.'; err.style.display='block'; });
  }
  insertChunk(0);
}

