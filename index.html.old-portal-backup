// ── Shared canvas helpers ───────────────────────────────────
function setCanvas(id, w, h) {
  var el = document.getElementById(id);
  el.width  = w;
  el.height = h;
  el.style.width  = '100%';
  el.style.height = 'auto';
  var ctx = el.getContext('2d');
  ctx.fillStyle = C.bg;
  ctx.fillRect(0, 0, w, h);
  return ctx;
}

function chartTitle(ctx, text, w) {
  ctx.fillStyle = C.text;
  ctx.font = 'bold 22px system-ui,sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText(text, w / 2, 36);
}

function wrapText(ctx, text, x, y, maxW, lineH) {
  var words = text.split(' '), line = '', lines = [];
  words.forEach(function(w) {
    var test = line ? line + ' ' + w : w;
    if (ctx.measureText(test).width > maxW && line) { lines.push(line); line = w; }
    else line = test;
  });
  lines.push(line);
  lines.forEach(function(l, i) { ctx.fillText(l, x, y + i * lineH); });
  return lines.length;
}

// ── Chart 2 — Influence & Friction Bars ────────────────────
function drawBarsChart(posData, negData, teamName) {
  var W = 900, PAD = 60, TOP = 60, BAR = 22, GAP = 10, LABEL_W = 160;
  var allPlayers = [];
  // Merge pos and neg into unified sorted list (by pos desc)
  var seen = {};
  posData.forEach(function(p) { seen[p.name] = {name:p.name, pos:p.val, neg:0}; });
  negData.forEach(function(n) {
    if (seen[n.name]) seen[n.name].neg = n.val;
    else seen[n.name] = {name:n.name, pos:0, neg:n.val};
  });
  allPlayers = Object.values(seen).sort(function(a,b){ return (b.pos+b.neg)-(a.pos+a.neg); }).slice(0,18);

  var H = TOP + allPlayers.length * (BAR + GAP) + 80;
  var ctx = setCanvas('rc-bars', W, H);
  chartTitle(ctx, 'Player Influence & Friction Breakdown', W);

  // Legend
  ctx.font = '13px system-ui,sans-serif';
  ctx.fillStyle = C.green; ctx.fillRect(PAD, 48, 14, 14);
  ctx.fillStyle = C.text;  ctx.textAlign = 'left'; ctx.fillText('Positive Mentions', PAD+18, 60);
  ctx.fillStyle = C.purple; ctx.fillRect(PAD+180, 48, 14, 14);
  ctx.fillStyle = C.text;  ctx.fillText('Negative Mentions', PAD+198, 60);

  var maxVal = Math.max.apply(null, allPlayers.map(function(p){return Math.max(p.pos,p.neg);})) || 1;
  var chartW  = W - PAD - LABEL_W - PAD;
  var midX    = PAD + LABEL_W; // zero line

  allPlayers.forEach(function(p, i) {
    var y = TOP + 30 + i * (BAR + GAP);

    // Name label
    ctx.fillStyle = C.text;
    ctx.font = '12px system-ui,sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText(p.name, midX - 6, y + BAR * 0.72);

    // Positive bar (right)
    if (p.pos > 0) {
      var pw = (p.pos / maxVal) * (chartW * 0.85);
      var grad = ctx.createLinearGradient(midX, 0, midX + pw, 0);
      grad.addColorStop(0, C.green); grad.addColorStop(1, C.greenL);
      ctx.fillStyle = grad;
      ctx.beginPath(); ctx.roundRect(midX + 2, y, pw, BAR, 3); ctx.fill();
      ctx.fillStyle = C.text; ctx.font = 'bold 11px system-ui,sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText(p.pos, midX + pw + 5, y + BAR * 0.75);
    }

    // Negative bar (also right, overlaid slightly offset)
    if (p.neg > 0) {
      var nw = (p.neg / maxVal) * (chartW * 0.85);
      ctx.fillStyle = 'rgba(192,57,43,0.18)';
      ctx.beginPath(); ctx.roundRect(midX + 2, y + BAR + 2, nw, 6, 2); ctx.fill();
      ctx.fillStyle = C.red;
      ctx.font = '10px system-ui,sans-serif'; ctx.textAlign = 'left';
      ctx.fillText('−'+p.neg, midX + nw + 5, y + BAR + 10);
    }

    // Zero line
    ctx.strokeStyle = C.border; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(midX, y - 2); ctx.lineTo(midX, y + BAR + 10); ctx.stroke();
  });

  // Full zero axis line
  ctx.strokeStyle = C.mid; ctx.lineWidth = 1.5;
  ctx.beginPath();
  ctx.moveTo(midX, TOP + 26);
  ctx.lineTo(midX, TOP + 30 + allPlayers.length * (BAR + GAP));
  ctx.stroke();

  // Watermark
  ctx.fillStyle = 'rgba(0,0,0,0.08)'; ctx.font = 'bold 13px system-ui,sans-serif';
  ctx.textAlign = 'right';
  ctx.fillText('RPM Systems Group · ' + teamName, W - PAD, H - 14);
}

// ── Chart 3 — Zone Card Grid ────────────────────────────────
function drawScatterChart(players, posData, negData, rolesMap, teamName) {
  var posMap = {}, negMap = {};
  posData.forEach(function(p){ posMap[p.name] = p.val; });
  negData.forEach(function(n){ negMap[n.name] = n.val; });

  // Group and sort players by zone
  var zones = {
    inf: {label:'CORE INFLUENCERS',   emoji:'🟢', col:'#1A7A4A', bg:'rgba(26,122,74,0.08)',   border:'rgba(26,122,74,0.40)',   players:[]},
    pol: {label:'POLARIZING FIGURES', emoji:'🟡', col:'#9a6800', bg:'rgba(176,120,0,0.08)',    border:'rgba(176,120,0,0.40)',    players:[]},
    rej: {label:'REJECTION RISK',     emoji:'🔴', col:'#C0392B', bg:'rgba(192,57,43,0.08)',    border:'rgba(192,57,43,0.40)',    players:[]},
    iso: {label:'ISOLATION RISK',     emoji:'🔵', col:'#3a6abf', bg:'rgba(58,106,191,0.08)',   border:'rgba(58,106,191,0.40)',   players:[]}
  };
  players.forEach(function(name) {
    var role = rolesMap[name];
    if (zones[role]) zones[role].players.push(name);
  });
  Object.values(zones).forEach(function(z) {
    z.players.sort(function(a,b){ return (posMap[b]||0)-(posMap[a]||0); });
  });

  // Sizing constants
  var PAD = 20, GAP = 14, COL_HDR = 40, ROW_H = 22, INNER_PAD = 12, CORNER = 8;
  var TITLE_H = 58; // space for chart title + subtitle

  // Pre-calculate each card height
  function cardHeight(z) {
    return COL_HDR + 18 + Math.max(z.players.length, 1) * ROW_H + INNER_PAD;
  }

  var zoneKeys = ['inf','pol','rej','iso'];
  var leftH  = cardHeight(zones['inf']) + GAP + cardHeight(zones['rej']);
  var rightH = cardHeight(zones['pol']) + GAP + cardHeight(zones['iso']);
  var totalH = TITLE_H + Math.max(leftH, rightH) + PAD + 24; // 24 for watermark

  var W = 900;
  var ctx = setCanvas('rc-scatter', W, totalH);
  var colW = (W - PAD * 2 - GAP) / 2;

  // Title
  ctx.fillStyle = '#111';
  ctx.font = 'bold 20px system-ui,sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('Team Risk Zone Analysis', W / 2, 30);
  ctx.font = '11px system-ui,sans-serif';
  ctx.fillStyle = '#666';
  ctx.fillText('All players grouped by social support and friction scores', W / 2, 50);

  function drawCard(zone, x, y) {
    var h = cardHeight(zone);

    // Card shadow
    ctx.fillStyle = 'rgba(0,0,0,0.04)';
    ctx.beginPath(); ctx.roundRect(x+2, y+2, colW, h, CORNER); ctx.fill();

    // Card background
    ctx.fillStyle = zone.bg;
    ctx.beginPath(); ctx.roundRect(x, y, colW, h, CORNER); ctx.fill();

    // Card border
    ctx.strokeStyle = zone.border; ctx.lineWidth = 1.5;
    ctx.beginPath(); ctx.roundRect(x, y, colW, h, CORNER); ctx.stroke();

    // Header
    ctx.fillStyle = zone.border;
    ctx.beginPath(); ctx.roundRect(x, y, colW, COL_HDR, [CORNER, CORNER, 0, 0]); ctx.fill();

    // Zone label
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 11px system-ui,sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText(zone.emoji + '  ' + zone.label, x + INNER_PAD, y + 25);

    // Player count badge
    var badgeW = 30, badgeH = 17;
    var bx = x + colW - badgeW - 10, by = y + (COL_HDR - badgeH) / 2;
    ctx.fillStyle = 'rgba(255,255,255,0.22)';
    ctx.beginPath(); ctx.roundRect(bx, by, badgeW, badgeH, 8); ctx.fill();
    ctx.fillStyle = '#fff'; ctx.font = 'bold 10px system-ui,sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(zone.players.length, bx + badgeW / 2, by + 12);

    // Column sub-headers
    var rowsY = y + COL_HDR + 14;
    ctx.fillStyle = zone.col; ctx.font = '9px system-ui,sans-serif';
    ctx.textAlign = 'left';  ctx.fillText('PLAYER', x + INNER_PAD, rowsY);
    ctx.textAlign = 'right'; ctx.fillText('+POS', x + colW - 70, rowsY);
    ctx.fillText('−NEG', x + colW - INNER_PAD, rowsY);

    // Divider
    ctx.strokeStyle = zone.border; ctx.lineWidth = 0.5;
    ctx.beginPath();
    ctx.moveTo(x + 6, rowsY + 5); ctx.lineTo(x + colW - 6, rowsY + 5);
    ctx.stroke();

    // Player rows
    if (zone.players.length === 0) {
      ctx.fillStyle = '#aaa'; ctx.font = 'italic 11px system-ui,sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('None identified', x + colW / 2, rowsY + ROW_H);
    } else {
      zone.players.forEach(function(name, pi) {
        var ry = rowsY + 8 + (pi + 1) * ROW_H;

        // Alternating row tint
        if (pi % 2 === 0) {
          ctx.fillStyle = 'rgba(0,0,0,0.025)';
          ctx.fillRect(x + 4, ry - 15, colW - 8, ROW_H);
        }

        var pos = posMap[name] || 0;
        var neg = negMap[name] || 0;

        ctx.fillStyle = '#111'; ctx.font = '12px system-ui,sans-serif';
        ctx.textAlign = 'left';
        ctx.fillText(name, x + INNER_PAD, ry);

        ctx.fillStyle = pos > 0 ? '#1A7A4A' : '#aaa';
        ctx.font = 'bold 11px system-ui,sans-serif';
        ctx.textAlign = 'right';
        ctx.fillText(pos > 0 ? '+' + pos : '0', x + colW - 70, ry);

        ctx.fillStyle = neg >= 10 ? '#C0392B' : neg >= 4 ? '#9a6800' : '#aaa';
        ctx.fillText(neg > 0 ? '−' + neg : '0', x + colW - INNER_PAD, ry);
      });
    }

    return h;
  }

  // Draw left column: inf, then rej below
  var leftX = PAD;
  var infH = drawCard(zones['inf'], leftX, TITLE_H);
  drawCard(zones['rej'], leftX, TITLE_H + infH + GAP);

  // Draw right column: pol, then iso below
  var rightX = PAD + colW + GAP;
  var polH = drawCard(zones['pol'], rightX, TITLE_H);
  drawCard(zones['iso'], rightX, TITLE_H + polH + GAP);

  // Watermark
  ctx.fillStyle = 'rgba(0,0,0,0.08)'; ctx.font = 'bold 12px system-ui,sans-serif';
  ctx.textAlign = 'right';
  ctx.fillText('RPM Systems Group · ' + teamName, W - PAD, totalH - 6);
}
// ── Chart 1 — Network Connectivity Map ─────────────────────
function drawNetworkChart(players, posData, negData, rolesMap, teamName) {
  var W = 900, H = 700;
  var ctx = setCanvas('rc-network', W, H);
  chartTitle(ctx, 'Team Connectivity: Roles & Zones', W);

  var posMap = {}, negMap = {};
  posData.forEach(function(p){ posMap[p.name]=p.val; });
  negData.forEach(function(n){ negMap[n.name]=n.val; });

  var roleColor = {inf:C.green, rej:'#C0392B', iso:'#6070C8', pol:C.purple, non:C.mid};

  // Deterministic hash so chart looks the same every time for the same data
  function strHash(s) {
    var h = 0;
    for (var i=0; i<s.length; i++) { h = ((h*31)+s.charCodeAt(i))>>>0; }
    return h;
  }

  // Position nodes in a circular layout, grouped loosely by role
  var cx = W/2, cy = H/2 + 10, R = 260;
  var nodes = {};
  var roleOrder = {inf:0, pol:1, rej:2, iso:3, non:4};
  var sorted = players.slice().sort(function(a,b){
    return (roleOrder[rolesMap[a]||'non']||0) - (roleOrder[rolesMap[b]||'non']||0);
  });
  sorted.forEach(function(name, i) {
    var angle = (i / players.length) * Math.PI * 2 - Math.PI/2;
    var r = R + ((strHash(name) % 30) - 15);
    nodes[name] = { x: cx + Math.cos(angle)*r, y: cy + Math.sin(angle)*r };
  });

  // Draw edges — pos=green, neg=red/purple dashed
  var maxPos = Math.max.apply(null, posData.map(function(p){return p.val;})) || 1;
  var maxNeg = Math.max.apply(null, negData.map(function(n){return n.val;})) || 1;

  // Positive edges: connect top influencers to everyone (simulate)
  var topInf = posData.slice().sort(function(a,b){return b.val-a.val;}).slice(0,8);
  topInf.forEach(function(src) {
    if (!nodes[src.name]) return;
    var connections = Math.min(6, Math.round((src.val/maxPos)*10));
    var others = players.filter(function(p){ return p!==src.name; });
    var seed = strHash(src.name);
    for (var i=0; i<connections && i<others.length; i++) {
      var tgt = others[(seed + i * 7) % others.length];
      if (!nodes[tgt]) return;
      var alpha = 0.12 + (src.val/maxPos)*0.18;
      ctx.strokeStyle = 'rgba(26,122,74,' + alpha + ')';
      ctx.lineWidth = 1 + (src.val/maxPos)*1.5;
      ctx.setLineDash([]);
      ctx.beginPath();
      ctx.moveTo(nodes[src.name].x, nodes[src.name].y);
      ctx.lineTo(nodes[tgt].x, nodes[tgt].y);
      ctx.stroke();
    }
  });

  // Negative edges: from high-friction players
  var topNeg = negData.slice().sort(function(a,b){return b.val-a.val;}).slice(0,4);
  topNeg.forEach(function(src) {
    if (!nodes[src.name]) return;
    var connections = Math.min(8, Math.round((src.val/maxNeg)*12));
    var others = players.filter(function(p){ return p!==src.name; });
    for (var i=0; i<connections && i<others.length; i++) {
      var tgt = others[i % others.length];
      if (!nodes[tgt]) return;
      ctx.strokeStyle = 'rgba(139,62,191,0.45)';
      ctx.lineWidth = 1.2;
      ctx.setLineDash([5,4]);
      ctx.beginPath();
      ctx.moveTo(nodes[src.name].x, nodes[src.name].y);
      ctx.lineTo(nodes[tgt].x, nodes[tgt].y);
      ctx.stroke();
    }
  });
  ctx.setLineDash([]);

  // Draw nodes
  players.forEach(function(name) {
    var n = nodes[name];
    var role = rolesMap[name]||'non';
    var col = roleColor[role];
    var pos = posMap[name]||0;
    var radius = 10 + (pos/maxPos)*12;

    ctx.beginPath(); ctx.arc(n.x, n.y, radius, 0, Math.PI*2);
    ctx.fillStyle = col + '55'; ctx.fill();
    ctx.strokeStyle = col; ctx.lineWidth = 2; ctx.stroke();

    // Name
    ctx.fillStyle = C.text;
    ctx.font = '10px system-ui,sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(name.split(' ')[0], n.x, n.y + radius + 13);
  });

  // Legend
  var legItems = [
    {col:C.green,  label:'Core Influencer'},
    {col:C.purple, label:'Polarizing Figure'},
    {col:'#C0392B',label:'Rejection Risk'},
    {col:'#6070C8', label:'Isolation Risk'},
    {col:'rgba(26,122,74,0.6)',  label:'Positive Connection', dash:false, line:true},
    {col:'rgba(139,62,191,0.6)', label:'Negative Connection', dash:true,  line:true},
  ];
  var lStartX = 20, lY = H - 28;
  ctx.font = '11px system-ui,sans-serif';
  var lx = lStartX;
  legItems.forEach(function(li) {
    if (li.line) {
      ctx.strokeStyle = li.col; ctx.lineWidth = 1.5;
      ctx.setLineDash(li.dash ? [4,3] : []);
      ctx.beginPath(); ctx.moveTo(lx, lY+3); ctx.lineTo(lx+22, lY+3); ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = C.text; ctx.textAlign = 'left';
      ctx.fillText(li.label, lx+26, lY+7);
      lx += ctx.measureText(li.label).width + 50;
    } else {
      ctx.beginPath(); ctx.arc(lx+6, lY+3, 6, 0, Math.PI*2);
      ctx.fillStyle = li.col+'55'; ctx.fill();
      ctx.strokeStyle = li.col; ctx.lineWidth = 1.5; ctx.stroke();
      ctx.fillStyle = C.text; ctx.textAlign = 'left';
      ctx.fillText(li.label, lx+16, lY+7);
      lx += ctx.measureText(li.label).width + 38;
    }
  });

  // Watermark
  ctx.fillStyle = 'rgba(0,0,0,0.08)'; ctx.font = 'bold 13px system-ui,sans-serif';
  ctx.textAlign = 'right';
  ctx.fillText('RPM Systems Group · ' + teamName, W - 20, H - 8);
}

// ── Render all three charts from data ──────────────────────
function renderReportCharts(players, posData, negData, rolesMap, teamName) {
  drawNetworkChart(players, posData, negData, rolesMap, teamName);
  drawBarsChart(posData, negData, teamName);
  drawScatterChart(players, posData, negData, rolesMap, teamName);
}

