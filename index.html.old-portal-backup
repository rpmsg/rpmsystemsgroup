<script>
(function(){

// ── Config ─────────────────────────────────────────────────
// credentials validated against admins table in Supabase
// credentials validated against admins table in Supabase

var SUPA_URL = 'https://skdcfigtjooffalsnwbf.supabase.co';
var SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNrZGNmaWd0am9vZmZhbHNud2JmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMyNTQ1MzIsImV4cCI6MjA4ODgzMDUzMn0.1A33rYXLvlRrUCbXRVT5tDsHbMyasO_OxdSHygL5WoY';
var PORTAL_URL = 'https://rpmsystemsgroup.com';

function supa(path, method, body) {
  return fetch(SUPA_URL + '/rest/v1/' + path, {
    method: method || 'GET',
    headers: {
      'apikey': SUPA_KEY,
      'Authorization': 'Bearer ' + SUPA_KEY,
      'Content-Type': 'application/json',
      'Prefer': method === 'POST' ? 'return=representation' : ''
    },
    body: body ? JSON.stringify(body) : undefined
  }).then(function(r){ return r.status === 204 ? {} : r.json(); });
}

// ── State ──────────────────────────────────────────────────
var TEAMS   = [];
var ROSTER  = [];
var COACHES = [];
var pendingResetId   = null;
var pendingResetName = '';
var csvParsedNames   = [];
var currentQRCode    = '';
var currentQRTeam    = '';

// ── Admin data (loaded live from Supabase) ────────────────
var DEMO_TEAMS   = [];
var DEMO_ROSTER  = [];
var DEMO_COACHES = [];
var DEMO_PANIC   = [];

// ── Auth ───────────────────────────────────────────────────
function adminLogin() {
  var em = document.getElementById("adm-email").value.trim();
  var pw = document.getElementById("adm-pass").value;
  var err = document.getElementById("adm-err");
  err.style.display = "none";
  var btn = document.querySelector("#s-admin-login .bp");
  if (btn) { btn.textContent = "Signing in..."; btn.style.opacity=".6"; btn.style.pointerEvents="none"; }
  supa("admins?email=eq." + encodeURIComponent(em) + "&select=id,full_name,password")
    .then(function(data) {
      if (btn) { btn.textContent = "Sign In →"; btn.style.opacity=""; btn.style.pointerEvents=""; }
      if (!data || !data.length || data[0].password !== pw) {
        err.style.display = "block"; return;
      }
      localStorage.setItem("rpm_admin_session", "1");
      document.getElementById("adm-user-label").textContent = data[0].full_name || em;
      show("s-admin");
      loadAllData();
    })
    .catch(function() {
      if (btn) { btn.textContent = "Sign In →"; btn.style.opacity=""; btn.style.pointerEvents=""; }
      err.textContent = "Connection error. Please try again.";
      err.style.display = "block";
    });
}

function adminLogout() {
  localStorage.removeItem('rpm_admin_session');
  localStorage.removeItem('rpm_screen');
  localStorage.removeItem('rpm_admin_section');
  document.getElementById('adm-email').value = '';
  document.getElementById('adm-pass').value = '';
  show('s-land');
}

// ── Load data ──────────────────────────────────────────────
function normaliseTeam(t) {
  // Supabase returns team_code — normalise to .code for all render functions
  return {
    id:       t.id,
    name:     t.name       || '',
    sport:    t.sport      || '',
    school:   t.school     || '',
    season:   t.season     || '',
    code:     t.team_code  || t.code || '',
    status:   t.status     || 'active',
    athletes: t.athletes   || 0,
    complete: t.complete   || 0
  };
}

function normaliseRoster(r) {
  return {
    id:       r.id,
    name:     r.full_name  || r.name || '',
    team:     r.team_id    || r.team || '',
    teamName: r.team_name  || r.teamName || '',
    status:   r.status     || 'pending',
    date:     r.completed_at ? new Date(r.completed_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '—'
  };
}

function normaliseCoach(c) {
  return {
    id:       c.id,
    name:     c.full_name  || c.name  || '',
    email:    c.email      || '',
    team:     c.team_id    || c.team  || '',
    teamName: c.team_name  || c.teamName || '',
    status:   c.status     || 'active'
  };
}

function loadAllData() {
  Promise.all([
    supa('teams?select=*&order=created_at.desc'),
    supa('roster?select=*&order=full_name'),
    supa('coaches?select=*&order=full_name')
  ]).then(function(results) {
    var rawTeams   = (results[0] && Array.isArray(results[0])) ? results[0] : [];
    var rawRoster  = (results[1] && Array.isArray(results[1])) ? results[1] : [];
    var rawCoaches = (results[2] && Array.isArray(results[2])) ? results[2] : [];

    TEAMS   = rawTeams.map(normaliseTeam);
    ROSTER  = rawRoster.map(function(r) {
      var norm = normaliseRoster(r);
      // Resolve team name from TEAMS array if not embedded
      if (!norm.teamName) {
        var team = TEAMS.find(function(t){ return t.id === norm.team; });
        norm.teamName = team ? team.name : '';
      }
      return norm;
    });
    COACHES = rawCoaches.map(function(co) {
      var norm = normaliseCoach(co);
      if (!norm.teamName) {
        var team = TEAMS.find(function(t){ return t.id === norm.team; });
        norm.teamName = team ? team.name : '';
      }
      return norm;
    });
    // Compute athletes/complete counts from ROSTER (not stored on teams table)
    TEAMS.forEach(function(t) {
      var tr = ROSTER.filter(function(r){ return r.team === t.id; });
      t.athletes = tr.length;
      t.complete  = tr.filter(function(r){ return r.status === 'complete'; }).length;
    });
    renderAll();
  }).catch(function() {
    TEAMS   = [];
    ROSTER  = [];
    COACHES = [];
    renderAll();
  });
}

function renderAll() {
  renderOverview();
  renderTeams();
  renderRoster();
  renderQRCodes();
  renderCoaches();
  renderResets();
  renderPanic();
  populateTeamSelects();
}

// ── Sidebar navigation ─────────────────────────────────────
function showSection(id, el) {
  document.querySelectorAll('.section').forEach(function(s){ s.classList.remove('on'); });
  document.getElementById('sec-' + id).classList.add('on');
  document.querySelectorAll('.nav-item').forEach(function(n){ n.classList.remove('active'); });
  if (el) el.classList.add('active');
  localStorage.setItem("rpm_admin_section", id);
}

function restoreAdminSection() {
  var sec = localStorage.getItem('rpm_admin_section') || 'overview';
  var navItem = null;
  document.querySelectorAll('.nav-item').forEach(function(n) {
    if ((n.getAttribute('onclick') || '').indexOf("'" + sec + "'") !== -1) navItem = n;
  });
  showSection(sec, navItem);
}

// ── Overview ───────────────────────────────────────────────
function renderOverview() {
  var active = TEAMS.filter(function(t){ return t.status === 'active'; });
  var totalA = TEAMS.reduce(function(s,t){ return s + (t.athletes||0); }, 0);
  var totalC = TEAMS.reduce(function(s,t){ return s + (t.complete||0); }, 0);
  document.getElementById('ov-teams').textContent   = active.length;
  document.getElementById('ov-athletes').textContent = totalA;
  document.getElementById('ov-complete').textContent = totalC;
  document.getElementById('ov-coaches').textContent  = COACHES.filter(function(c){ return c.status==='active'; }).length;

  var h = '';
  TEAMS.forEach(function(t) {
    var pct = t.athletes ? Math.round((t.complete/t.athletes)*100) : 0;
    h += '<div class="tbl-row" style="grid-template-columns:1.5fr 1fr 100px 100px 80px 80px">'
       + '<div style="font-weight:600">' + t.name + '</div>'
       + '<div style="color:var(--mid)">' + t.school + '</div>'
       + '<div><code style="font-size:10px;color:var(--gl)">' + t.code + '</code></div>'
       + '<div style="color:var(--mid);font-size:11px">' + t.season + '</div>'
       + '<div>'
       +   '<div style="font-size:11px;color:var(--mid);margin-bottom:4px">' + t.complete + '/' + t.athletes + '</div>'
       +   '<div class="prog-bar"><div class="prog-fill" style="width:' + pct + '%"></div></div>'
       + '</div>'
       + '<div><span class="pill ' + (t.status==='active'?'pill-g':'pill-mid') + '">' + t.status + '</span></div>'
       + '</div>';
  });
  document.getElementById('ov-team-rows').innerHTML = h || '<div class="tbl-empty">No teams yet</div>';
}

