function buildPanicProfileFromData(panicRows) {
  if (!panicRows || !panicRows.length) {
    buildChartsEmpty();
    return;
  }
  var total = panicRows.length;

  function tally(field) {
    var counts = {};
    panicRows.forEach(function(r) {
      var val = r[field];
      if (val) counts[val] = (counts[val] || 0) + 1;
    });
    return Object.keys(counts)
      .sort(function(a,b){ return counts[b]-counts[a]; })
      .slice(0,5)
      .map(function(k) {
        var pct = Math.round((counts[k]/total)*100);
        var color = pct >= 50 ? 'r' : pct >= 30 ? 'y' : 'b';
        return {label: k, pct: pct, color: color};
      });
  }

  var triggers   = tally('q1_trigger');
  var behaviors  = tally('q8_behavior');
  var aftermaths = tally('q11_aftermath');

  // Build insights from the top results
  var insights = [];
  if (triggers[0])   insights.push({color:'r', text:'<strong>'+triggers[0].pct+'%</strong> of athletes trigger on: '+triggers[0].label});
  if (behaviors[0])  insights.push({color:'r', text:'<strong>'+behaviors[0].pct+'%</strong> primary behavioral response: '+behaviors[0].label.toLowerCase()});
  if (aftermaths[0]) insights.push({color:'b', text:'<strong>'+aftermaths[0].pct+'%</strong> aftermath pattern: '+aftermaths[0].label.toLowerCase()});
  if (triggers[1])   insights.push({color:'y', text:'<strong>'+triggers[1].pct+'%</strong> secondary trigger: '+triggers[1].label.toLowerCase()});

  buildPanicProfile({
    triggers:  triggers,
    behaviors: behaviors.concat(aftermaths).slice(0,6),
    insights:  insights
  });
}

