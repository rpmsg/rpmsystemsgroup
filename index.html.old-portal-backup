function buildRiskGrid(scoresData) {
  var zones = [
    {t:'🟢 CORE INFLUENCERS',c:'g',d:'High support, low friction',role:'Core Influencer'},
    {t:'🔴 REJECTION RISK',c:'r',d:'Low support, high friction',role:'Rejection Risk'},
    {t:'🔵 ISOLATION RISK',c:'b',d:'Low support, low friction',role:'Isolation Risk'},
    {t:'🟡 POLARIZING FIGURES',c:'y',d:'High support, high friction',role:'Polarizing Figure'}
  ];
  var rh = '';
  zones.forEach(function(z) {
    var players = scoresData.filter(function(s){return s.social_role===z.role;});
    rh += '<div class="rq"><div class="rqt ' + z.c + '">' + z.t + '</div><div class="rqd">' + z.d + '</div><div class="rqp">';
    if (players.length) {
      players.forEach(function(p) { rh += '<div class="rqpi">' + p.athlete_name.split(' ')[0] + '</div>'; });
    } else {
      rh += '<span style="font-size:10px;color:var(--mid)">None identified</span>';
    }
    rh += '</div></div>';
  });
  document.getElementById('risk-grid').innerHTML = rh;
}

function buildSuggestions(scoresData) {
  var topFriction = scoresData.slice().sort(function(a,b){return b.negative_mentions-a.negative_mentions;});
  var sg = [];
  if (topFriction[0] && topFriction[0].negative_mentions > 0) {
    sg.push({i:'⚠️', t:'<strong>' + topFriction[0].athlete_name + '</strong> — Friction score is a significant outlier (−' + topFriction[0].negative_mentions + '). Consider a private 1:1 conversation before drawing conclusions.'});
  }
  if (topFriction[1] && topFriction[1].negative_mentions > 0) {
    sg.push({i:'🔍', t:'<strong>' + topFriction[1].athlete_name + (topFriction[2] ? ' &amp; ' + topFriction[2].athlete_name : '') + '</strong> — Elevated friction with limited peer support. Understanding the source may reveal fixable dynamics.'});
  }
  var isoCount = scoresData.filter(function(s){return s.social_role==='Isolation Risk';}).length;
  if (isoCount > 0) {
    sg.push({i:'🔗', t:'<strong>' + isoCount + ' Isolation Risk player' + (isoCount>1?'s':'') + '</strong> — Intentional grouping with Core Influencers in training and travel may help build connection naturally.'});
  }
  if (!sg.length) {
    sg.push({i:'✅', t:'<strong>No significant friction patterns detected.</strong> Team dynamics look healthy based on current data. Continue monitoring as more athletes complete the assessment.'});
  }
  var sh = '';
  sg.forEach(function(s) { sh += '<div class="si"><span class="sico">' + s.i + '</span><p class="stxt">' + s.t + '</p></div>'; });
  document.getElementById('suggestions').innerHTML = sh;
}

