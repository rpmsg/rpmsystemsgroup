function getReportData() {
  var complete = lastRosterData.filter(function(r){ return r.status==='complete'; }).length;
  var pending  = lastRosterData.length - complete;
  var coreInf  = lastScoresData.filter(function(s){ return s.social_role==='Core Influencer'; }).length;
  var friction = lastScoresData.filter(function(s){ return s.negative_mentions>=8; }).length;
  var posPlayers = lastScoresData.slice().sort(function(a,b){ return b.positive_mentions-a.positive_mentions; })
    .map(function(s){ return [s.athlete_name, s.positive_mentions]; });
  var negPlayers = lastScoresData.slice().sort(function(a,b){ return b.negative_mentions-a.negative_mentions; })
    .filter(function(s){ return s.negative_mentions>0; })
    .map(function(s){ return [s.athlete_name, s.negative_mentions]; });
  var suggs = [];
  document.querySelectorAll('#suggestions .stxt').forEach(function(el){ suggs.push(el.textContent); });
  return {
    stats: { complete:complete, pending:pending, influencers:coreInf, frictionFlags:friction },
    posPlayers: posPlayers,
    negPlayers: negPlayers,
    suggestions: suggs
  };
}

function downloadReport() {
  var btn = document.getElementById('btn-download-report');
  var prog = document.getElementById('dl-progress');
  prog.classList.add('on');
  btn.style.display = 'none';

  var teamLabel = (document.getElementById('dash-title') || {textContent:'Team'}).textContent.trim()
    || (document.querySelector('.dhd h2') || {textContent:'Team'}).textContent.trim();
  var status = document.getElementById('dl-status');

  var charts = [
    {id:'rc-network',  name:'Chart1_Connectivity_Map.png'},
    {id:'rc-bars',     name:'Chart2_Influence_Friction.png'},
    {id:'rc-scatter',  name:'Chart3_Risk_Zones.png'}
  ];
  var i = 0;

  function downloadNext() {
    if (i >= charts.length) {
      // ── Generate PDF ───────────────────────────────────
      status.textContent = 'Building Pulse Report PDF...';
      setTimeout(function() {
        try {
          var data    = getReportData();
          var html    = buildPDFContent(teamLabel, data);
          var win     = window.open('','_blank','width=900,height=700');
          win.document.write(html);
          win.document.close();
          win.focus();
          setTimeout(function(){ win.print(); }, 600);
          prog.innerHTML = '<span>✅</span><span>All 3 charts downloaded. PDF report opened for printing/saving.</span>';
          btn.textContent = '✓ Done'; btn.style.display = '';
          btn.className = 'btn bo'; btn.removeAttribute('data-action');
        } catch(e) {
          prog.innerHTML = '<span>⚠</span><span>Charts saved. PDF failed: ' + e.message + '</span>';
          btn.textContent = '✓ Done'; btn.style.display = '';
          btn.className = 'btn bo'; btn.removeAttribute('data-action');
        }
      }, 400);
      return;
    }
    var ch = charts[i++];
    status.textContent = 'Saving ' + ch.name + '...';
    var canvas = document.getElementById(ch.id);
    canvas.toBlob(function(blob) {
      var a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = ch.name;
      a.click();
      URL.revokeObjectURL(a.href);
      setTimeout(downloadNext, 600);
    }, 'image/png');
  }
  downloadNext();
}

// ── Coach roster export ────────────────────────────────────
function exportCoachRoster() {
  if (!lastRosterData.length) { alert('No roster data to export.'); return; }
  var roleMap = {'Core Influencer':'Core Influencer','Rejection Risk':'Rejection Risk','Isolation Risk':'Isolation Risk','Polarizing Figure':'Polarizing Figure'};
  var rows = 'athlete_name,status,social_role,friction_score\n';
  lastRosterData.forEach(function(r) {
    var score = lastScoresData.find(function(s){ return s.athlete_name === r.full_name; });
    var role  = score ? (roleMap[score.social_role] || '—') : '—';
    var fric  = score ? score.negative_mentions : 0;
    rows += '"'+r.full_name+'","'+(r.status==='complete'?'Complete':'Pending')+'","'+role+'",'+fric+'\n';
  });
  var blob = new Blob([rows], {type:'text/csv'});
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'Roster_' + new Date().toISOString().slice(0,10) + '.csv';
  a.click();
  URL.revokeObjectURL(a.href);
}
window.exportCoachRoster = exportCoachRoster;

// ── Event delegation ───────────────────────────────────────
document.addEventListener('DOMContentLoaded', function() {
  document.addEventListener('click', function(e) {
    var el = e.target.closest('[data-action]');
    if (!el) return;
    var a = el.getAttribute('data-action');
    var t = el.getAttribute('data-target');
    if      (a === 'show')               show(t);
    else if (a === 'valCode')            valCode();
    else if (a === 'proceedFromConsent') proceedFromConsent();
    else if (a === 'openPrivacy')        openPrivacyModal();
    else if (a === 'startPC')            startPC();
    else if (a === 'donePC') {
      if (!validateCurrent('pc', 11)) return;
      donePC();
    }
    else if (a === 'startSM')            startSM();
    else if (a === 'submitIntake')       submitIntake();
    else if (a === 'coachLogin')         coachLogin();
    else if (a === 'openModal')          openModal();
    else if (a === 'closeModal')         closeModal();
    else if (a === 'downloadReport')     downloadReport();
    else if (a === 'selR')               selR(el);
    else if (a === 'npc') {
      var npcN = parseInt(el.getAttribute('data-n'));
      var npcCur = document.querySelector('.qb.on');
      if (npcCur) { var npcM = npcCur.id.match(/^q-pc(\d+)$/); if (npcM && npcN > parseInt(npcM[1]) && !validateCurrent('pc', parseInt(npcM[1]))) return; }
      npc(npcN);
    }
    else if (a === 'nsm') {
      var nsmN = parseInt(el.getAttribute('data-n'));
      var nsmCur = document.querySelector('.qb.on');
      if (nsmCur) { var nsmM = nsmCur.id.match(/^q-sm(\d+)$/); if (nsmM && nsmN > parseInt(nsmM[1]) && !validateCurrent('sm', parseInt(nsmM[1]))) return; }
      nsm(nsmN);
    }
    else if (a === 'single')             single(el, el.getAttribute('data-key'));
    else if (a === 'multi')              multi(el, el.getAttribute('data-key'), parseInt(el.getAttribute('data-max')));
  });
  document.getElementById('report-modal').addEventListener('click', function(e) {
    if (e.target === document.getElementById('report-modal')) closeModal();
  });
  document.addEventListener('change', function(e) {
    var el = e.target.closest('[data-action]');
    if (!el) return;
    if (el.getAttribute('data-action') === 'toggleConsent') toggleConsent();
  });
  // Pre-fill team code from URL parameter (QR code scan)
  var urlCode = new URLSearchParams(window.location.search).get('code');
  if (urlCode) {
    document.getElementById('inp-code').value = urlCode.toUpperCase();
    show('s-code');
  }
});

})();
