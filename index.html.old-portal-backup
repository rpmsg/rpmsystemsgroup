// ── Export ─────────────────────────────────────────────────
function exportCSV(type) {
  var labels = {social:'Social_Map_Responses',panic:'Panic_Cycle_Responses',scores:'Pulse_Report_Scores',roster:'Roster_Status'};
  showToast('Preparing export...');

  function download(header, rows) {
    var csv  = header + rows;
    var blob = new Blob([csv], {type:'text/csv'});
    var a    = document.createElement('a');
    a.href   = URL.createObjectURL(blob);
    a.download = labels[type] + '_' + new Date().toISOString().slice(0,10) + '.csv';
    a.click();
    URL.revokeObjectURL(a.href);
    showToast('Exported ' + labels[type] + '.csv');
  }

  if (type === 'roster') {
    var rows = '';
    ROSTER.forEach(function(r){
      rows += '"'+r.name+'","'+r.teamName+'","'+r.status+'","'+r.date+'"\n';
    });
    download('athlete_name,team,status,submitted_date\n', rows);

  } else if (type === 'panic') {
    supa('panic_cycle_responses?select=*').then(function(data) {
      var rows = '';
      (data||[]).forEach(function(p) {
        var rosterRow = ROSTER.find(function(r){ return r.id === p.athlete_id; });
        var teamRow   = TEAMS.find(function(t){ return t.id === p.team_id; });
        var name = rosterRow ? rosterRow.name : p.athlete_id;
        var team = teamRow   ? teamRow.name   : p.team_id;
        rows += '"'+name+'","'+team+'",'
              + '"'+(p.q1_trigger||'')+'",'
              + '"'+(p.q2_first_signal||'')+'",'
              + '"'+(p.q3_emotions||'')+'",'
              + '"'+(p.q4_inner_voice||'')+'",'
              + '"'+(p.q5_identity_phrase||'')+'",'
              + '"'+(p.q6_body_response||'')+'",'
              + '"'+(p.q7_reaction||'')+'",'
              + '"'+(p.q8_behavior||'')+'",'
              + '"'+(p.q9_pattern_sentence||'')+'",'
              + '"'+(p.q10_outcome||'')+'",'
              + '"'+(p.q11_aftermath||'')+'"\n';
      });
      download('athlete_name,team,trigger,first_signal,emotions,inner_voice,identity,body_response,reaction,behavior,pattern,outcome,aftermath\n', rows);
    });

  } else if (type === 'social') {
    supa('social_map_responses?select=*&order=athlete_id,question_number').then(function(data) {
      var rows = '';
      (data||[]).forEach(function(s) {
        var rosterRow = ROSTER.find(function(r){ return r.id === s.athlete_id; });
        var teamRow   = TEAMS.find(function(t){ return t.id === s.team_id; });
        var name = rosterRow ? rosterRow.name : s.athlete_id;
        var team = teamRow   ? teamRow.name   : s.team_id;
        if (s.nominee_1) rows += '"'+name+'","'+team+'",'+s.question_number+',"'+s.nominee_1+'","'+s.question_type+'"\n';
        if (s.nominee_2) rows += '"'+name+'","'+team+'",'+s.question_number+',"'+s.nominee_2+'","'+s.question_type+'"\n';
      });
      download('athlete_name,team,question_number,nominated_player,type\n', rows);
    });

  } else if (type === 'scores') {
    supa('pulse_report_scores?select=*&order=team_id,positive_mentions.desc').then(function(data) {
      var rows = '';
      (data||[]).forEach(function(s) {
        var teamRow = TEAMS.find(function(t){ return t.id === s.team_id; });
        var team = teamRow ? teamRow.name : s.team_id;
        rows += '"'+s.athlete_name+'","'+team+'",'+s.positive_mentions+','+s.negative_mentions+',"'+s.social_role+'"\n';
      });
      download('athlete_name,team,positive_mentions,negative_mentions,social_role\n', rows);
    });
  }
}

