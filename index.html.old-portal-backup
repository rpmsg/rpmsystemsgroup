// ── Panic Cycles ───────────────────────────────────────────
function renderPanic(filterTeam) {
  var sel = document.getElementById('panic-team-filter');
  if (sel && !sel.options.length) {
    sel.innerHTML = '<option value="">All Teams</option>';
    TEAMS.forEach(function(t){ sel.innerHTML += '<option value="' + t.id + '">' + t.name + '</option>'; });
  }
  var PANIC = [];
  var items = filterTeam ? PANIC.filter(function(p){ return p.team===filterTeam; }) : PANIC;
  var stages = [
    {key:'trigger',  label:'Trigger'},
    {key:'emotion',  label:'Emotion'},
    {key:'body',     label:'Body Response'},
    {key:'reaction', label:'Reaction'},
    {key:'behavior', label:'Behavior'},
    {key:'aftermath',label:'Aftermath'}
  ];
  var h = '';
  items.forEach(function(p) {
    h += '<div class="pc-card">'
       + '<div class="pc-card-hd"><span class="pc-card-name">' + p.name + '</span>'
       + '<span class="pill pill-g">Complete</span></div>'
       + '<div class="pc-stages">';
    stages.forEach(function(st) {
      h += '<div class="pc-stage"><div class="pc-stage-lbl">' + st.label + '</div>'
         + '<div class="pc-stage-val">' + (p[st.key] || '—') + '</div></div>';
    });
    h += '</div></div>';
  });
  document.getElementById('panic-cards').innerHTML = h || '<div style="color:var(--mid);font-size:12px;padding:20px 0">No completed panic cycles found.</div>';
