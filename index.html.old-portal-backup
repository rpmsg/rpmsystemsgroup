function createTeam() {
  var name   = document.getElementById('nt-name').value.trim();
  var sport  = document.getElementById('nt-sport').value.trim();
  var school = document.getElementById('nt-school').value.trim();
  var season = document.getElementById('nt-season').value.trim();
  var code   = document.getElementById('nt-code').value.trim().toUpperCase() ||
               name.replace(/\s+/g,'').toUpperCase().slice(0,6) + new Date().getFullYear().toString().slice(2);
  var err = document.getElementById('nt-err');
  var suc = document.getElementById('nt-suc');
  if (!name || !school) { err.textContent='Team name and school are required.'; err.style.display='block'; return; }
  err.style.display = 'none';
  err.style.display = 'none';
  var btn = document.querySelector('#modal-new-team .modal-foot .bp');
  if (btn) { btn.textContent = 'Creating...'; btn.style.opacity='.6'; btn.style.pointerEvents='none'; }
  supa('teams', 'POST', {name:name, sport:sport, school:school, season:season, team_code:code, status:'active'})
    .then(function(data) {
      if (btn) { btn.textContent='Create Team'; btn.style.opacity=''; btn.style.pointerEvents=''; }
      if (!data || data.code || data.error) {
        err.textContent = (data && (data.message||data.error)) || 'Failed to create team. Please try again.';
        err.style.display = 'block'; return;
      }
      var created = Array.isArray(data) ? data[0] : data;
      TEAMS.push({id:created.id, name:name, sport:sport, school:school, season:season, code:code, status:'active', athletes:0, complete:0});
      renderAll();
      suc.textContent = 'Team "' + name + '" created. Code: ' + code;
      suc.style.display = 'block';
      setTimeout(function(){ closeModal('modal-new-team'); suc.style.display='none';
        document.getElementById('nt-name').value=''; document.getElementById('nt-sport').value='';
        document.getElementById('nt-school').value=''; document.getElementById('nt-season').value='';
        document.getElementById('nt-code').value=''; }, 2000);
    })
    .catch(function(e) {
      if (btn) { btn.textContent='Create Team'; btn.style.opacity=''; btn.style.pointerEvents=''; }
      err.textContent = 'Connection error. Please try again.'; err.style.display='block';
    });
}

function editTeam(id) {
  var team = TEAMS.find(function(t){ return t.id === id; });
  if (!team) return;
  document.getElementById('et-id').value    = team.id;
  document.getElementById('et-name').value  = team.name;
  document.getElementById('et-sport').value = team.sport;
  document.getElementById('et-school').value= team.school;
  document.getElementById('et-season').value= team.season;
  document.getElementById('et-err').style.display = 'none';
  document.getElementById('et-suc').style.display = 'none';
  openModal('modal-edit-team');
}

function saveTeam() {
  var id     = document.getElementById('et-id').value;
  var name   = document.getElementById('et-name').value.trim();
  var sport  = document.getElementById('et-sport').value.trim();
  var school = document.getElementById('et-school').value.trim();
  var season = document.getElementById('et-season').value.trim();
  var err    = document.getElementById('et-err');
  var suc    = document.getElementById('et-suc');
  if (!name || !school) { err.textContent = 'Team name and school are required.'; err.style.display = 'block'; return; }
  err.style.display = 'none';
  supa('teams?id=eq.' + id, 'PATCH', {name: name, sport: sport, school: school, season: season})
    .then(function() {
      var team = TEAMS.find(function(t){ return t.id === id; });
      if (team) { team.name = name; team.sport = sport; team.school = school; team.season = season; }
      renderTeams(); renderOverview(); populateTeamSelects();
      suc.textContent = 'Team updated.'; suc.style.display = 'block';
      setTimeout(function(){ closeModal('modal-edit-team'); suc.style.display = 'none'; }, 1500);
    })
    .catch(function(){ err.textContent = 'Failed to save changes.'; err.style.display = 'block'; });
}

function toggleTeam(id) {
  var team = TEAMS.find(function(t){ return t.id===id; });
  if (!team) return;
  var newStatus = team.status === 'active' ? 'inactive' : 'active';
  supa('teams?id=eq.' + id, 'PATCH', {status: newStatus})
    .then(function() { team.status = newStatus; renderTeams(); renderOverview(); })
    .catch(function() { alert('Failed to update team status.'); });
}

function deleteTeam(id) {
  var team = TEAMS.find(function(t){ return t.id===id; });
  if (!team) return;
  var playerCount = ROSTER.filter(function(r){ return r.team === id; }).length;
  var msg = 'Permanently delete "' + team.name + '"?\n\n'
          + 'This will also delete ' + playerCount + ' roster player' + (playerCount === 1 ? '' : 's') + '.\n\n'
          + 'This cannot be undone.';
  if (!confirm(msg)) return;
  supa('roster?team_id=eq.' + id, 'DELETE')
    .then(function() { return supa('teams?id=eq.' + id, 'DELETE'); })
    .then(function() {
      TEAMS  = TEAMS.filter(function(t){ return t.id !== id; });
      ROSTER = ROSTER.filter(function(r){ return r.team !== id; });
      renderAll();
    })
    .catch(function() { alert('Failed to delete team. Please try again.'); });
}

