function generatePanicPDF() {
  if (!PANIC.length) { showToast('No panic cycle responses to export yet.'); return; }
  var today = new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
  var cards = '';
  PANIC.forEach(function(p) {
    function row(label, question, val) {
      if (!val) return '';
      return '<div style="margin-bottom:12px">'
           + '<div style="font-size:9px;text-transform:uppercase;letter-spacing:1.5px;color:#1A7A4A;font-weight:700;margin-bottom:1px">' + label + '</div>'
           + '<div style="font-size:9px;color:#999;margin-bottom:4px">' + question + '</div>'
           + '<div style="font-size:12px;color:#222;line-height:1.5;padding:8px 12px;background:#f5f5f5;border-radius:6px">' + val + '</div></div>';
    }
    cards += '<div style="page-break-after:always;padding:40px 48px;font-family:Arial,sans-serif">'
           + '<div style="border-bottom:3px solid #1A7A4A;padding-bottom:16px;margin-bottom:24px">'
           + '<div style="font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#888;margin-bottom:4px">RPM Systems Group — Panic Cycle Profile</div>'
           + '<div style="font-size:26px;font-weight:900;color:#1A7A4A">' + p.athlete + '</div>'
           + '<div style="font-size:12px;color:#888;margin-top:2px">' + p.teamName + ' &nbsp;·&nbsp; Generated ' + today + ' &nbsp;·&nbsp; Confidential — Practitioner Only</div>'
           + '</div>'
           + row('Q1 — Primary Trigger',    'What type of situation most often starts your cycle?',         p.trigger)
           + row('Q2 — First Signal',       'When this happens, what is the first thing you notice?',       p.signal)
           + row('Q3 — Emotions',           'Which emotions feel closest in those moments?',                p.emotion)
           + row('Q4 — Inner Voice',        'What is your most common automatic thought?',                  p.voice)
           + row('Q5 — Identity',           'Which phrase feels closest to your experience?',               p.identity)
           + row('Q6 — Body Response',      'What happens in your body?',                                   p.body)
           + row('Q7 — Reaction',           'What emotional reaction usually shows up?',                    p.reaction)
           + row('Q8 — Behavior',           'What do you usually do next?',                                 p.behavior)
           + row('Q10 — Outcome',           'What usually happens after this sequence?',                    p.outcome)
           + row('Q11 — Aftermath',         'How do you usually feel afterward?',                           p.aftermath)
           + (p.pattern ? '<div style="margin-top:20px;padding:14px 16px;border-left:4px solid #1A7A4A;background:#f0f9f4;border-radius:0 8px 8px 0">'
              + '<div style="font-size:9px;text-transform:uppercase;letter-spacing:1.5px;color:#1A7A4A;font-weight:700;margin-bottom:2px">Q9 &#8212; Pattern (Athlete&#39;s Own Words)</div>'
              + '<div style="font-size:9px;color:#999;margin-bottom:6px">In one sentence, what does this look like for you?</div>'
              + '<div style="font-size:13px;font-style:italic;color:#333">&ldquo;' + p.pattern + '&rdquo;</div></div>' : '')
           + '</div>';
  });
  var html = '<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Panic Cycle Profiles</title>'
           + '<style>*{box-sizing:border-box;margin:0;padding:0}body{background:#fff;color:#111}@media print{body{-webkit-print-color-adjust:exact;print-color-adjust:exact}}</style>'
           + '</head><body>' + cards + '</body></html>';
  var w = window.open('', '_blank');
  if (!w) { showToast('Please allow pop-ups to generate the PDF.'); return; }
  w.document.write(html);
  w.document.close();
  w.focus();
  setTimeout(function(){ w.print(); }, 400);
}
// ── Modal helpers ──────────────────────────────────────────
function openModal(id) {
  document.getElementById(id).classList.add('on');
  document.body.style.overflow = 'hidden';
}
function closeModal(id) {
  document.getElementById(id).classList.remove('on');
  document.body.style.overflow = '';
}

// ── Toast notification ─────────────────────────────────────
function showToast(msg) {
  var t = document.createElement('div');
  t.textContent = msg;
  t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1a1a1a;border:1px solid rgba(255,255,255,.12);color:#fff;padding:11px 20px;border-radius:8px;font-size:12px;z-index:999;box-shadow:0 4px 20px rgba(0,0,0,.4);max-width:400px;text-align:center';
  document.body.appendChild(t);
  setTimeout(function(){ t.style.opacity='0'; t.style.transition='opacity .4s'; setTimeout(function(){ t.remove(); },400); }, 2800);
}

// ── Upload drag/drop ───────────────────────────────────────
document.addEventListener('DOMContentLoaded', function(){
  var zone = document.getElementById('upload-zone');
  if (!zone) return;
  zone.addEventListener('dragover', function(e){ e.preventDefault(); zone.classList.add('drag'); });
  zone.addEventListener('dragleave', function(){ zone.classList.remove('drag'); });
  zone.addEventListener('drop', function(e){
    e.preventDefault(); zone.classList.remove('drag');
    var file = e.dataTransfer.files[0];
    if (file) { var inp = document.getElementById('csv-file'); inp.files = e.dataTransfer.files; window.handleCSV(inp); }
  });
  // Close modals on overlay click
  document.querySelectorAll('.modal-overlay').forEach(function(m){
    m.addEventListener('click', function(e){ if(e.target===m) closeModal(m.id); });
  });
  // Enter key on login
  document.getElementById('adm-pass').addEventListener('keydown', function(e){ if(e.key==='Enter') adminLogin(); });
});

