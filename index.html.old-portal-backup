// ── Recalculate pulse scores after each submission ─────────
function recalculatePulseScores() {
  return supa('social_map_responses?team_id=eq.' + teamId + '&select=question_type,nominee_1,nominee_2')
    .then(function(rows) {
      if (!rows || !rows.length) return;
      var pos = {};
      var neg = {};
      rows.forEach(function(r) {
        [r.nominee_1, r.nominee_2].forEach(function(nm) {
          if (!nm) return;
          if (r.question_type === 'positive') { pos[nm] = (pos[nm]||0) + 1; }
          else                               { neg[nm] = (neg[nm]||0) + 1; }
        });
      });
      var allNames = Object.keys(Object.assign({}, pos, neg));
      var avgPos = allNames.reduce(function(s,n){return s+(pos[n]||0);},0) / (allNames.length||1);
      var avgNeg = allNames.reduce(function(s,n){return s+(neg[n]||0);},0) / (allNames.length||1);
      var upserts = allNames.map(function(nm) {
        var p = pos[nm]||0, n = neg[nm]||0;
        var role = p >= avgPos && n <= avgNeg ? 'Core Influencer'
                 : p >= avgPos && n >  avgNeg ? 'Polarizing Figure'
                 : p <  avgPos && n >  avgNeg ? 'Rejection Risk'
                 : 'Isolation Risk';
        return {
          team_id: teamId,
          athlete_name: nm,
          positive_mentions: p,
          negative_mentions: n,
          social_role: role,
          avg_positive: avgPos,
          avg_negative: avgNeg,
          last_calculated: new Date().toISOString()
        };
      });
      return supa('pulse_report_scores?team_id=eq.' + teamId, 'DELETE', null)
        .then(function() { return supa('pulse_report_scores', 'POST', upserts); });
    });
}

