    var sel = getRosterSelected('r-sm' + q);
    sm.push({
      athlete_id:      athleteId,
      team_id:         teamId,
      question_number: q,
      question_type:   q <= 9 ? 'positive' : 'negative',
      nominee_1:       sel.n1,
      nominee_2:       sel.n2
    });
  }

  // Save panic cycle
  supa('panic_cycle_responses', 'POST', pc)
    .then(function() {
      // Save all social map rows
      return supa('social_map_responses', 'POST', sm);
    })
    .then(function() {
      // Mark athlete complete
      return supa('roster?id=eq.' + athleteId, 'PATCH', {
        status: 'complete',
        completed_at: new Date().toISOString()
      });
    })
    .then(function() {
      // Recalculate pulse scores for team
      return recalculatePulseScores();
    })
    .then(function() {
      // Check if full roster is complete — trigger coach notification check
      return checkRosterComplete();
    })
    .then(function() {
      // Show confirmation with personalized summary
      window.removeEventListener('beforeunload', warnBeforeLeave);
      populateConfirmation(pc);
      setLoading('btn-submit', false, 'Submit Assessment ✓');
      show('s-confirm');
    })
    .catch(function(err) {
      showErr('submit-err', 'Submission error. Please try again or notify your coach.');
      setLoading('btn-submit', false, 'Submit Assessment ✓');
    });
